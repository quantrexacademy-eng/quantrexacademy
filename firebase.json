{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git/**",
      "data/clean_shards/**",
      "data/banks/**",
      "data/qx_image_scan.json",
      "assets/clean-diagrams/**",
      "**/node_modules/**",
      "marks_data/**",
      "tools/**",
      "pdf_pages/**",
      "scripts/**",
      "**/*.bat",
      "**/*.exe",
      "**/*.py",
      "**/*.pyc",
      "data_old.js",
      "landing_old.html",
      "main_site.html"
    ],
    "headers": [
      {
        "source": "**/*.{js,css}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
        ]
      },
      {
        "source": "**/*.{svg,png,jpg,jpeg,webp,woff,woff2,ico}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "data/**/*.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/login", "destination": "/login.html" },
      { "source": "/app", "destination": "/app.html" },
      { "source": "/dashboard", "destination": "/app.html" }
    ]
  }
}