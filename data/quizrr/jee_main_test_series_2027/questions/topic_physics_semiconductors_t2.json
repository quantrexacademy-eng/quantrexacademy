[{"id":43444,"subject":"Physics","chapter":"Semiconductors","question":"","options":["24 mA","80 mA","10 mA","60 mA"],"answer":2,"solution":"<img src=\"https://.app/pyq/jee_main/RaxUT7pm499Pkoq5Vn3-Re6vWq3Q_DL1MZwjMgG3qHI.original.fullsize.png\"/><br/>$\\mathrm{V}_1=\\frac{400}{100+400} \\times 12 \\mathrm{~V}=\\frac{4}{5} \\times 12=\\frac{48}{5} \\mathrm{~V}$<br/>here, $\\mathrm{V}_1 \\gt \\mathrm{V}_{\\mathrm{z}},\\left(\\mathrm{V}_{\\mathrm{z}}=\\right.$ Zener Voltage $)$ So, Zener breakdown will be take place So, voltage across $400 \\Omega$ will be 4 V<br/>$\\mathrm{I}=\\frac{4}{400} \\mathrm{~A}=\\frac{1}{100 \\mathrm{~A}}=10 \\mathrm{~mA}$","type":"mcq","source":"JEE Main 2025 (7 Apr Shift 1)","image":null},{"id":43599,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math><mn>0.33</mn><mi mathvariant=\"normal\"> </mi><mi mathvariant=\"normal\">k</mi><mi mathvariant=\"normal\">Ω</mi><mo>,</mo><mi mathvariant=\"normal\"> </mi><mn>1.5</mn></math>","<math><mn>0.67</mn><mi mathvariant=\"normal\"> </mi><mi mathvariant=\"normal\">k</mi><mi mathvariant=\"normal\">Ω</mi><mo>,</mo><mi mathvariant=\"normal\"> </mi><mn>300</mn></math>","<math><mn>0.67</mn><mi mathvariant=\"normal\"> </mi><mi mathvariant=\"normal\">k</mi><mi mathvariant=\"normal\">Ω</mi><mo>,</mo><mi mathvariant=\"normal\"> </mi><mn>200</mn></math>","0.33 k <math><mi mathvariant=\"normal\">Ω</mi><mo>,</mo><mi mathvariant=\"normal\"> </mi><mn>300</mn></math>"],"answer":1,"solution":"<p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>l</mi><mi>o</mi><mi>a</mi><mi>d</mi><mo>&#160;</mo><mi>r</mi><mi>e</mi><mi>s</mi><mi>i</mi><mi>s</mi><mi>t</mi><mi>a</mi><mi>c</mi><mi>e</mi><mo>=</mo><mi>o</mi><mi>u</mi><mi>t</mi><mi>p</mi><mi>u</mi><mi>t</mi><mo>&#160;</mo><mi>r</mi><mi>e</mi><mi>s</mi><mi>i</mi><mi>s</mi><mi>t</mi><mi>a</mi><mi>c</mi><mi>e</mi><msub><mi>R</mi><mi>L</mi></msub><mo>=</mo><mn>1</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">k</mi><mi mathvariant=\"normal\">&#937;</mi><mo>=</mo><mn>1000</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">&#937;</mi></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#160;</mo><mi>i</mi><mi>n</mi><mi>p</mi><mi>u</mi><mi>t</mi><mo>&#160;</mo><mi>v</mi><mi>o</mi><mi>l</mi><mi>t</mi><mi>a</mi><mi>g</mi><mi>e</mi><mo>=</mo><mi>&#916;</mi><msub><mi>V</mi><mi>i</mi></msub><mo>=</mo><mn>10</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">V</mi><mo>=</mo><mn>10</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup><mtext>&#8201;</mtext><mi mathvariant=\"normal\">V</mi></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>i</mi><mi>n</mi><mi>p</mi><mi>u</mi><mi>t</mi><mo>&#160;</mo><mi>c</mi><mi>u</mi><mi>r</mi><mi>r</mi><mi>e</mi><mi>n</mi><mi>t</mi><mo>=</mo><mi>b</mi><mi>a</mi><mi>s</mi><mi>e</mi><mo>&#160;</mo><mi>c</mi><mi>u</mi><mi>r</mi><mi>r</mi><mi>e</mi><mi>n</mi><mi>t</mi><mo>=</mo><mi>&#916;</mi><msub><mi>i</mi><mi>B</mi></msub><mo>=</mo><mn>15</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">&#956;</mi><mi mathvariant=\"normal\">A</mi><mo>=</mo><mn>15</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>6</mn></mrow></msup><mtext>&#8201;</mtext><mi mathvariant=\"normal\">A</mi></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>o</mi><mi>u</mi><mi>t</mi><mi>p</mi><mi>u</mi><mi>t</mi><mo>&#160;</mo><mi>c</mi><mi>u</mi><mi>r</mi><mi>r</mi><mi>e</mi><mi>n</mi><mi>t</mi><mo>=</mo><mi>c</mi><mi>o</mi><mi>l</mi><mi>l</mi><mi>e</mi><mi>c</mi><mi>t</mi><mi>o</mi><mi>r</mi><mo>&#160;</mo><mi>c</mi><mi>u</mi><mi>r</mi><mi>r</mi><mi>e</mi><mi>n</mi><mi>t</mi><mo>=</mo><mi>&#916;</mi><msub><mi>i</mi><mi>C</mi></msub><mo>=</mo><mn>3</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">A</mi><mo>=</mo><mn>3</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup><mtext>&#8201;</mtext><mi mathvariant=\"normal\">A</mi></math><br /><math><mi>&#916;</mi><msub><mrow><mi>i</mi></mrow><mrow><mi>B</mi></mrow></msub><msub><mrow><mi>R</mi></mrow><mrow><mi>i</mi></mrow></msub><mo>=</mo><mi>&#916;</mi><msub><mrow><mi>V</mi></mrow><mrow><mi>i</mi></mrow></msub><mo>=</mo><mn>0.67</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">k</mi><mi mathvariant=\"normal\">&#937;</mi></math><br /><math><msub><mrow><mi>R</mi></mrow><mrow><mi>i</mi></mrow></msub><mo>=</mo><mfrac><mrow><mn>10</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mo>-</mo><mn>3</mn></mrow></msup></mrow><mrow><mn>15</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mo>-</mo><mn>6</mn></mrow></msup></mrow></mfrac><mo>=</mo><mn>0.67</mn><mtext>&#8201;</mtext><mi mathvariant=\"normal\">k</mi><mi mathvariant=\"normal\">&#937;</mi></math><br />Voltage gain <math><mo>=</mo><mfrac><mrow><mi>&#916;</mi><msub><mrow><mi>I</mi></mrow><mrow><mi>C</mi></mrow></msub><msub><mrow><mi>R</mi></mrow><mrow><mi>L</mi></mrow></msub></mrow><mrow><mi>&#916;</mi><msub><mrow><mi>V</mi></mrow><mrow><mi>i</mi></mrow></msub></mrow></mfrac><mo>=</mo><mfrac><mrow><mn>3</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mo>-</mo><mn>3</mn></mrow></msup><mo>&#215;</mo><mn>1000</mn></mrow><mrow><mn>10</mn><mo>&#215;</mo><msup><mrow><mn>10</mn></mrow><mrow><mo>-</mo><mn>3</mn></mrow></msup></mrow></mfrac><mo>=</mo><mn>300</mn></math></p>","type":"mcq","source":"JEE Main 2019 (09 Apr Shift 1)","image":null},{"id":43476,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>8</mn><mo>.</mo><mn>75</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo> </mo><mn>9</mn><mo>.</mo><mn>00</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>8</mn><mo>.</mo><mn>50</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>14</mn><mo>.</mo><mn>00</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math>"],"answer":0,"solution":"<blockquote><p><img src=\"https://.app/pyq/jee_main/6359c29b-4b03-4bca-8c6d-7bf1bcb624ec.png\" style=\"width: 350px; height: 176px;\"/></p><p>Both diodes are in forward bias. In forward bias, potential drop across <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>G</mi><mi>e</mi></math> and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>S</mi><mi>i</mi></math> will be <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>3</mn><mo> </mo><mi mathvariant=\"normal\">V</mi><mo> </mo><mo>&amp;</mo><mo> </mo><mn>0</mn><mo>.</mo><mn>7</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math> respectively.</p><p>Therefore, current in the circuit <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>i</mi><mo>=</mo><mfrac><mrow><mn>15</mn><mo>-</mo><mn>0</mn><mo>.</mo><mn>3</mn><mo>-</mo><mn>0</mn><mo>.</mo><mn>7</mn></mrow><mrow><mn>4</mn><mo>×</mo><mn>1000</mn></mrow></mfrac><mo>=</mo><mn>3</mn><mo>.</mo><mn>5</mn><mo> </mo><mi>mA</mi></math></p><p>Required potential drop across <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>R</mi><mi>L</mi></msub></math>, <br/><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>V</mi><mi mathvariant=\"normal\">L</mi></msub><mo>=</mo><mi>i</mi><msub><mi>R</mi><mi mathvariant=\"normal\">L</mi></msub><mo>=</mo><mfenced><mrow><mn>3</mn><mo>.</mo><mn>5</mn><mo>×</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup></mrow></mfenced><mo>×</mo><mfenced><mrow><mn>2</mn><mo>.</mo><mn>5</mn><mo>×</mo><mn>1000</mn></mrow></mfenced><mo> </mo><mi mathvariant=\"normal\">V</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mn>8</mn><mo>.</mo><mn>75</mn><mo> </mo><mi mathvariant=\"normal\">V</mi><mo> </mo></math></p></blockquote>","type":"mcq","source":"JEE Main 2024 (30 Jan Shift 2)","image":null},{"id":43524,"subject":"Physics","chapter":"Semiconductors","question":"","options":["Both&nbsp;A&nbsp;and R&nbsp;true, and R&nbsp;is correct explanation of A.","Both A&nbsp;and R&nbsp;are true but R&nbsp;is NOT the correct explanation of A.","A is true but R&nbsp;is false.","A is false but R&nbsp;is true."],"answer":0,"solution":"<p>A <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">n</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">p</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">n</mi></math>&nbsp;transistor&nbsp;has more electrons than holes, and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">p</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">n</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">p</mi></math>&nbsp;transistor&nbsp;has more holes than electrons. When a voltage is applied,&nbsp;then the movement of electrons is greater than holes. Therefore, conduction current in <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">n</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">p</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">n</mi></math>&nbsp;transistor&nbsp;is more than that in <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">p</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">n</mi><mo>&#8208;</mo><mi mathvariant=\"normal\">p</mi></math>&nbsp;transistor.</p><p>Both statements are true.</p>","type":"mcq","source":"JEE Main 2022 (28 Jun Shift 1)","image":null},{"id":43468,"subject":"Physics","chapter":"Semiconductors","question":"","options":["$\\mathrm{A}=0, \\mathrm{~B}=0, \\mathrm{C}=0, \\mathrm{D}=1$","$\\mathrm{A}=0, \\mathrm{~B}=1, \\mathrm{C}=1, \\mathrm{D}=1$","$\\mathrm{A}=1, \\mathrm{~B}=0, \\mathrm{C}=0, \\mathrm{D}=0$","$\\mathrm{A}=1, \\mathrm{~B}=1, \\mathrm{C}=1, \\mathrm{D}=0$"],"answer":2,"solution":"Bulb will glow if bulb have potential drop on it. One end of bulb must be at high (1) and other must be at low (0).\nOption (3) satisfy this condition\n<img src=\"https://.app/pyq/jee_main/DEpomuw8j6JG8zgonzwiPEQy2DscwpWNNxVe75qAYUU.original.fullsize.png\"><br>","type":"mcq","source":"JEE Main 2024 (05 Apr Shift 1)","image":null},{"id":43597,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math><mn>6</mn><mo>×</mo><msup><mrow><mn>10</mn></mrow><mrow><mn>2</mn></mrow></msup></math>","<math><msup><mrow><mn>10</mn></mrow><mrow><mn>2</mn></mrow></msup></math>","<math><msup><mrow><mn>10</mn></mrow><mrow><mn>4</mn></mrow></msup></math>","<math><mn>60</mn></math>"],"answer":1,"solution":"<p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>A</mi><mi>v</mi></msub><mo>&#215;</mo><mi>&#946;</mi><mo>=</mo><msub><mi>P</mi><mrow><mi>gain</mi><mo>&#160;</mo></mrow></msub></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>60</mn><mo>=</mo><mn>10</mn><msub><mi>log</mi><mn>10</mn></msub><mfenced><mfrac><mi>P</mi><msub><mi>P</mi><mn>0</mn></msub></mfrac></mfenced></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>P</mi><mo>=</mo><msup><mn>10</mn><mn>6</mn></msup><mo>=</mo><msup><mi>&#946;</mi><mn>2</mn></msup><mo>&#215;</mo><mfrac><msub><mi>R</mi><mrow><mi>out</mi><mo>&#160;</mo></mrow></msub><msub><mi>R</mi><mrow><mi>in</mi><mo>&#160;</mo></mrow></msub></mfrac><mo>=</mo><msup><mi>&#946;</mi><mn>2</mn></msup><mo>&#215;</mo><mfrac><msup><mn>10</mn><mn>4</mn></msup><mn>100</mn></mfrac></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mi>&#946;</mi><mn>2</mn></msup><mo>=</mo><msup><mn>10</mn><mn>4</mn></msup></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#946;</mi><mo>=</mo><mn>100</mn><mo>=</mo><msup><mn>10</mn><mn>2</mn></msup></math></p>","type":"mcq","source":"JEE Main 2019 (10 Apr Shift 1)","image":null},{"id":43552,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>OR</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>AND</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>NOR</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>NAND</mi></math>"],"answer":1,"solution":"<img src=\"https://.app/pyq/jee_main/130b696d-8a5c-4ce1-90a8-178e7c259c02-image.png\" style=\"width: 335px; height: 145px;\" />","type":"mcq","source":"JEE Main 2021 (25 Jul Shift 1)","image":null},{"id":43620,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<p><img src=\"https://.app/pyq/jee_main/828e293a-8d31-4012-8f15-d2b43be32e2f-image.png\" style=\"width: 230px; height: 153px;\" /></p>","<p><img src=\"https://.app/pyq/jee_main/c2c22ed3-b49b-4a09-906f-e45f4686af86-image.png\" style=\"width: 230px; height: 156px;\" /></p>","<p><img src=\"https://.app/pyq/jee_main/d97d28c3-9560-47db-97a2-e7b465be003e-image.png\" style=\"width: 230px; height: 155px;\" /></p>","<p><img src=\"https://.app/pyq/jee_main/4034251a-6cbd-401d-a780-8ca154cb6f9f-image.png\" style=\"width: 230px; height: 153px;\" /></p><p>&nbsp;</p>"],"answer":1,"solution":"When <math> <mrow>  <msub>   <mi>V</mi>   <mrow>    <mi>B</mi><mi>E</mi></mrow>  </msub>  </mrow></math> exceeds barrier potential current starts following and gets saturated after some values","type":"mcq","source":"JEE Main 2016 (10 Apr Online)","image":null},{"id":43556,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>R</mi><mi>d</mi></msub><mo>=</mo><mfrac><mrow><mi>d</mi><mi>V</mi></mrow><mrow><mi>d</mi><mi>i</mi></mrow></mfrac><mo>=</mo><mfrac><mn>1</mn><mfenced><mfrac><mrow><mi>d</mi><mi>i</mi></mrow><mrow><mi>d</mi><mi>v</mi></mrow></mfrac></mfenced></mfrac><mo>=</mo><mfrac><mn>1</mn><mfenced><mfrac><mrow><mn>5</mn><mo>-</mo><mn>1</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup></mrow><mrow><mn>0</mn><mo>.</mo><mn>75</mn><mo>-</mo><mn>0</mn><mo>.</mo><mn>65</mn></mrow></mfrac></mfenced></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>100</mn><mn>4</mn></mfrac><mo>=</mo><mn>25</mn><mo>&#160;</mo><mi mathvariant=\"normal\">&#937;</mi></math></p>","type":"mcq","source":"JEE Main 2021 (20 Jul Shift 2)","image":null},{"id":43477,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>50</mn><mo> </mo><mi>mA</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>30</mn><mo> </mo><mi>mA</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>20</mn><mo> </mo><mi>mA</mi></math>"],"answer":2,"solution":"<p><img src=\"https://.app/pyq/jee_main/955e162a-ed23-4ea4-a99d-7fb69927fbd4.png\" style=\"width: 250px; height: 154px;\"/></p><p>As Zener is in breakdown region, therefore potential drop across it would be <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>10</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math>. Now, </p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>I</mi><mn>3</mn></msub><mo>=</mo><mfrac><mn>10</mn><mn>500</mn></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>50</mn></mfrac><mo> </mo><mi mathvariant=\"normal\">A</mi></math> and </p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>I</mi><mn>1</mn></msub><mo>=</mo><mfrac><mn>10</mn><mn>200</mn></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>20</mn></mfrac><mo> </mo><mi mathvariant=\"normal\">A</mi></math></p><p>Also, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>I</mi><mn>2</mn></msub><mo>=</mo><msub><mi>I</mi><mn>1</mn></msub><mo>-</mo><msub><mi>I</mi><mn>3</mn></msub></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>⇒</mo><msub><mi>I</mi><mn>2</mn></msub><mo>=</mo><mfenced><mrow><mfrac><mn>1</mn><mn>20</mn></mfrac><mo>-</mo><mfrac><mn>1</mn><mn>50</mn></mfrac></mrow></mfenced><mo>=</mo><mfenced><mfrac><mn>3</mn><mn>100</mn></mfrac></mfenced><mo> </mo><mi mathvariant=\"normal\">A</mi><mo>=</mo><mn>30</mn><mo> </mo><mi>mA</mi></math></p>","type":"mcq","source":"JEE Main 2024 (30 Jan Shift 1)","image":null},{"id":43613,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>13</mn><mo>.5</mo><mi mathvariant=\"normal\">&#160;</mi><mi>mA</mi></math>","<math><mn>0</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>15</mn><mi mathvariant=\"normal\">&#160;</mi><mi>mA</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>11</mn><mo>.5</mo><mi mathvariant=\"normal\">&#160;</mi><mi>mA</mi></math>"],"answer":3,"solution":"<p>Given, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>R</mi><mo>=</mo><mn>200</mn><mo>&#160;</mo><mi mathvariant=\"normal\">&#937;</mi></math>&nbsp;and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>V</mi><mo>=</mo><mn>3</mn><mo>&#160;</mo><mi mathvariant=\"normal\">V</mi></math>. We have to calculate the current. We know that, a potential barrier across silicon diode <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mn>0.7</mn><mo>&#160;</mo><mi mathvariant=\"normal\">V</mi></math>.<br /><img src=\"https://.app/pyq/jee_main/d21cdd39-d3fb-4891-82b1-43ecf2e12439-image.png\" style=\"width: 240px; height: 182px;\" /></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>V</mi><mo>=</mo><mi>I</mi><mi>R</mi></math><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>I</mi><mo>=</mo><mfrac><mrow><mn>3</mn><mo>-</mo><mn>0.7</mn></mrow><mn>200</mn></mfrac><mo>=</mo><mn>0</mn><mo>.</mo><mn>0115</mn><mo>&#160;</mo><mi mathvariant=\"normal\">A</mi><mo>=</mo><mn>11</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi>mA</mi></math></p><p>So, the current is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>11</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi>mA</mi></math>.</p>","type":"mcq","source":"JEE Main 2018 (08 Apr)","image":null},{"id":43531,"subject":"Physics","chapter":"Semiconductors","question":"","options":["AND gate","OR gate","NOR gate","NAND gate"],"answer":0,"solution":"<p><img src=\"https://.app/pyq/jee_main/b7dc9b21-f736-4ac1-8595-5558b1416717-image.png\" style=\"width: 550px; height: 223px;\" /></p><p>According to the circuit,</p><p>Output<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mover><mrow><mover><mi mathvariant=\"normal\">A</mi><mo>&#175;</mo></mover><mo>+</mo><mover><mi mathvariant=\"normal\">B</mi><mo>&#175;</mo></mover></mrow><mo>&#175;</mo></mover></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right left right left right left right left right left right left\" columnspacing=\"0em 2em 0em 2em 0em 2em 0em 2em 0em 2em 0em\" rowspacing=\"3pt\"><mtr><mtd></mtd><mtd><mo>=</mo><mover><mi mathvariant=\"normal\">A</mi><mo accent=\"false\">&#175;</mo></mover><mo>&#8901;</mo><mover><mi mathvariant=\"normal\">B</mi><mo accent=\"false\">&#175;</mo></mover></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo><mi mathvariant=\"normal\">A</mi><mo>&#8901;</mo><mi mathvariant=\"normal\">B</mi></mtd></mtr></mtable></math></p><p>Thus, the given circuit is a AND gate.</p>","type":"mcq","source":"JEE Main 2022 (25 Jun Shift 2)","image":null},{"id":43544,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p><img src=\"https://.app/pyq/jee_main/6d8624fe-55db-40dd-b01a-9b7f98cf326a-image.png\" style=\"width: 342px; height: 193px;\" /></p><p>Diodes are forward biased, so they act as wire so input current is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math>&nbsp;as input source is short circuited output current is also zero, as input current is zero</p><p>Now, output voltage <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">V</mi></math></p>","type":"mcq","source":"JEE Main 2021 (27 Aug Shift 1)","image":null},{"id":43626,"subject":"Physics","chapter":"Semiconductors","question":"","options":["linear increase for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Cu</mi></math>, exponential decrease for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Si</mi></math>","linear decrease for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Cu</mi></math>, linear decrease for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Si</mi></math>","linear increase for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Cu</mi></math>, linear increase for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Si</mi></math>","linear increase for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Cu</mi></math>, exponential increase for <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Si</mi></math>"],"answer":0,"solution":"<p>Resistance variation with temperature: resistance of a metal increases with increase in temperature linearly and resistance of a semiconductor decreases exponentially with increase in temperature.</p><p><img src=\"https://.app/pyq/jee_main/2e4663bc-4a67-4ae3-ad2d-7052b8a2859c-image.png\" style=\"width: 250px; height: 159px;\" /></p>","type":"mcq","source":"JEE Main 2016 (03 Apr)","image":null},{"id":43664,"subject":"Physics","chapter":"Semiconductors","question":"","options":["the depletion region is reduced and barrier height is increased","the depletion region is widened and barrier height is reduced","both the depletion region and barrier height reduced","both the depletion region and barrier height increased."],"answer":2,"solution":"No Solution Available","type":"mcq","source":"JEE Main 2004","image":null},{"id":43434,"subject":"Physics","chapter":"Semiconductors","question":"","options":["17.6","18.8","11.7","20.15"],"answer":1,"solution":"$12 - 0.3 \\times 10^3 I - 0.7 = 0$<br>$\\dfrac{11.3}{0.3 \\times 10^3} = I$<br>$37.66 \\times 10^{-3} \\text{ A} = I$<br>Current through diode $D_1$, $I_1 = I/2$<br>$I_1 = 18.83 \\text{ mA}$","type":"mcq","source":"JEE Main 2026 (28 January Shift 1)","image":null},{"id":43516,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable><mtr><mtd><mi>A</mi></mtd><mtd><mi>B</mi></mtd><mtd><mi>Y</mi></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd></mtr></mtable></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable><mtr><mtd><mi>A</mi></mtd><mtd><mi>B</mi></mtd><mtd><mi>Y</mi></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd></mtr></mtable></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable><mtr><mtd><mi>A</mi></mtd><mtd><mi>B</mi></mtd><mtd><mi>Y</mi></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd></mtr></mtable></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable><mtr><mtd><mi>A</mi></mtd><mtd><mi>B</mi></mtd><mtd><mi>Y</mi></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd></mtr></mtable></math>"],"answer":0,"solution":"<blockquote><p>When both <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>A</mi></math> and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>B</mi></math> have logical value &lsquo;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math>&rsquo; both diode are reverse bias and current will flow in resistor hence output will be <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>5</mn></math> volt i.e. logical value &lsquo;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math>&rsquo;.</p><p>In all other case conduction will take place, hence output will be zero volt i.e. logical value &lsquo;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math>&rsquo;. So truth table is</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable><mtr><mtd><mi>A</mi></mtd><mtd><mi>B</mi></mtd><mtd><mi>Y</mi></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>0</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>0</mn></mtd><mtd><mn>0</mn></mtd></mtr><mtr><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd><mtd><mn>1</mn></mtd></mtr></mtable></math></p><p>Thus, given circuit is equivalent to an AND gate.</p></blockquote>","type":"mcq","source":"JEE Main 2022 (25 Jul Shift 1)","image":null},{"id":43566,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<p><img src=\"https://.app/pyq/jee_main/41af3bc3-8e86-4b31-a2f7-5050a745eaf3-image.png\" style=\"width: 200px; height: 85px;\" /></p>","<p><img src=\"https://.app/pyq/jee_main/843e6bd8-0106-465c-9e26-5a3f21578616-image.png\" style=\"width: 200px; height: 82px;\" /></p>","<p><img src=\"https://.app/pyq/jee_main/a278244b-d4b2-4acd-87b0-87fe26f55e21-image.png\" style=\"width: 200px; height: 84px;\" /></p>","<p><img src=\"https://.app/pyq/jee_main/f65f0750-f00a-4c3c-8aa1-a428ae0390e0-image.png\" style=\"width: 200px; height: 85px;\" /></p>"],"answer":0,"solution":"According to gates by Demorgan&#39;s law&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover><mrow><mover><mi>A</mi><mo>&#175;</mo></mover><mo>+</mo><mi>B</mi></mrow><mo>&#175;</mo></mover><mo>=</mo><mi>A</mi><mo>&#183;</mo><mover><mi>B</mi><mo>&#175;</mo></mover></math>&nbsp;By observation.","type":"mcq","source":"JEE Main 2021 (26 Feb Shift 2)","image":null},{"id":43526,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>Here diode&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>D</mi><mn>1</mn></msub></math> is forward biased and diode <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>D</mi><mn>2</mn></msub></math> is reverse biased.</p><p>So, no current will flow through diode&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>D</mi><mn>2</mn></msub></math>&nbsp;resistor.</p><p>Current through the resistor of&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>40</mn><mo>&#160;</mo><mi mathvariant=\"normal\">&#937;</mi></math>&nbsp;is&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>i</mi><mo>=</mo><mfrac><mrow><mn>1</mn><mo>-</mo><mn>0</mn><mo>.</mo><mn>6</mn></mrow><mrow><mn>60</mn><mo>+</mo><mn>40</mn></mrow></mfrac><mo>=</mo><mfrac><mrow><mn>0</mn><mo>.</mo><mn>4</mn></mrow><mn>100</mn></mfrac><mo>=</mo><mn>4</mn><mo>&#160;</mo><mi>mA</mi></math></p>","type":"mcq","source":"JEE Main 2022 (27 Jun Shift 2)","image":null},{"id":43639,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A NAND B","A OR B","AAND B","ANOR B"],"answer":0,"solution":"The output at $\\mathrm{C}$ corresponds to A NAND\n$$\n\\mathrm{B} \\text { or } \\overline{\\mathrm{A} \\cdot \\mathrm{B}}=\\mathrm{C}\n$$","type":"mcq","source":"JEE Main 2013 (09 Apr Online)","image":null},{"id":43605,"subject":"Physics","chapter":"Semiconductors","question":"","options":["$0.0 \\mathrm{~mA}$","$6.7 \\mathrm{~mA}$","$4.0 \\mathrm{~mA}$","$6.0 \\mathrm{~mA}$"],"answer":0,"solution":"Since voltage across zener diode does not reach to breakdown voltage therefore its resistance will be infinite \\& current through it is $0 .$","type":"mcq","source":"JEE Main 2019 (11 Jan Shift 1)","image":null},{"id":43656,"subject":"Physics","chapter":"Semiconductors","question":"","options":["All $E_c, E_g, E_v$ decrease","All F $F_{-F}$ increase","$\\mathrm{E}_{\\mathrm{c}}$, and $\\mathrm{E}_{\\mathrm{v}}$ increase but $\\mathrm{E}_{\\mathrm{g}}$ decreases","$E_c$, and $E_v$, decrease $E_g$ increases"],"answer":3,"solution":"$=(8 \\times 7.06-7 \\times 5.60) \\mathrm{MeV}=17.28 \\mathrm{MeV}$","type":"mcq","source":"JEE Main 2006","image":null},{"id":43471,"subject":"Physics","chapter":"Semiconductors","question":"","options":["$6 \\Omega$","$(5 / 2) \\Omega$","$(15 / 4) \\Omega$","$(30 / 11) \\Omega$"],"answer":0,"solution":"<img src=\"https://.app/pyq/jee_main/yBOlssAOZoI28FJtkwlk0QgzgWMhmhPZC4So51uWQG0.original.fullsize.png\"><br />Diode 2 is in reverse bias\nSo current will not flow in branch of $2^{\\text {nd }}$ diode, So we can assume it to be broken wire.\nDiode 1 is in forward bias\nSo it will behave like conducting wire. So new circuit will be<img src=\"https://.app/pyq/jee_main/Lia0N2rSLP84bAbXzbn0MdeewAQxK_Lj9SsVczbTn8M.original.fullsize.png\"><br>","type":"mcq","source":"JEE Main 2024 (04 Apr Shift 1)","image":null},{"id":43440,"subject":"Physics","chapter":"Semiconductors","question":"","options":["1101","0011","1000","0100"],"answer":0,"solution":"The LED will glow if it is forward biased, which means the potential at the p-side must be higher than the potential at the n-side.<br>Let $Y_1$ be the output of the upper NAND gate (p-side) and $Y_2$ be the output of the lower NOR gate (n-side).<br>For the LED to glow, we need $Y_1 = 1$ and $Y_2 = 0$.<br>The upper circuit consists of two NOT gates (NOR gates with shorted inputs) followed by a NAND gate.<br>Output of first NOT gate is $\\bar{A}$, and second is $\\bar{B}$.<br>$Y_1 = \\overline{\\bar{A} \\cdot \\bar{B}} = \\overline{\\bar{A}} + \\overline{\\bar{B}} = A + B$ (using De Morgan's Law).<br>The lower circuit is a NOR gate with inputs $C$ and $D$.<br>$Y_2 = \\overline{C + D}$.<br>Condition 1: $Y_1 = 1 \\implies A + B = 1$. This means at least one of $A$ or $B$ must be 1.<br>Condition 2: $Y_2 = 0 \\implies \\overline{C + D} = 0 \\implies C + D = 1$. This means at least one of $C$ or $D$ must be 1.<br>Checking the options:<br>(1) $A=1, B=1, C=0, D=1$: $Y_1 = 1+1 = 1$ and $Y_2 = \\overline{0+1} = 0$. (Satisfied)<br>(2) $A=0, B=0, C=1, D=1$: $Y_1 = 0+0 = 0$. (Not satisfied)<br>(3) $A=1, B=0, C=0, D=0$: $Y_2 = \\overline{0+0} = 1$. (Not satisfied)<br>(4) $A=0, B=1, C=0, D=0$: $Y_2 = \\overline{0+0} = 1$. (Not satisfied)<br>Thus, the correct combination is 1101.","type":"mcq","source":"JEE Main 2026 (22 January Shift 1)","image":null},{"id":43565,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A","B","C","D"],"answer":0,"solution":"<img src=\"https://.app/pyq/jee_main/d3e1f06e-0012-4a05-aa16-90ab28de3bc1-image.png\" style=\"width: 369px; height: 142px;\" />","type":"mcq","source":"JEE Main 2021 (16 Mar Shift 1)","image":null},{"id":43555,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>P</mi><mo>=</mo><mi>V</mi><mi>i</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>5</mn><mo>=</mo><mn>8</mn><mi>i</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>i</mi><mo>=</mo><mfrac><mn>1</mn><mn>16</mn></mfrac><mo>&#160;</mo><mi>A</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>E</mi><mo>=</mo><mn>20</mn><mo>=</mo><mn>8</mn><mo>+</mo><mi>i</mi><msub><mi>R</mi><mi>P</mi></msub></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>R</mi><mi>P</mi></msub><mo>=</mo><mn>12</mn><mo>&#215;</mo><mn>16</mn><mo>=</mo><mn>192</mn><mo>&#160;</mo><mi mathvariant=\"normal\">&#937;</mi></math></p>","type":"mcq","source":"JEE Main 2021 (20 Jul Shift 2)","image":null},{"id":43479,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>3</mn><mo>.</mo><mn>3</mn><mo> </mo><mi>mA</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>5</mn><mo>.</mo><mn>5</mn><mo> </mo><mi>mA</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>10</mn><mo> </mo><mi>mA</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>7</mn><mo> </mo><mi>mA</mi></math>"],"answer":1,"solution":"<p><img src=\"https://.app/pyq/jee_main/9b363b48-3941-41b4-9005-f38115f9ef53.png\" style=\"width: 350px; height: 233px;\"/></p><p>Given that, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>V</mi><mi>z</mi></msub><mo>=</mo><mn>3</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math></p><p>Let potential at <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>B</mi><mo>=</mo><mn>0</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math><br/>Potential at <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>E</mi><mfenced><msub><mi>V</mi><mi>E</mi></msub></mfenced><mo>=</mo><mn>10</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math></p><p>Now, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>V</mi><mi>C</mi></msub><mo>=</mo><msub><mi>V</mi><mi>A</mi></msub><mo>=</mo><mn>3</mn><mo> </mo><mi mathvariant=\"normal\">V</mi></math> and,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>I</mi><mi>z</mi></msub><mo>+</mo><msub><mi>I</mi><mn>1</mn></msub><mo>=</mo><mi>I</mi><mo> </mo><mo> </mo><mo> </mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>1</mn></mfenced></math></p><p>The current through <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn><mo> </mo><mi>kΩ</mi></math> resistor is given by</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>I</mi></mtd><mtd><mo>=</mo></mtd><mtd><mfrac><mrow><mn>10</mn><mo>-</mo><mn>3</mn></mrow><mn>1000</mn></mfrac><mo> </mo><mi mathvariant=\"normal\">A</mi></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mfrac><mn>7</mn><mn>1000</mn></mfrac><mo> </mo><mi mathvariant=\"normal\">A</mi></mtd></mtr></mtable></math></p><p>From the diagram, it follows that</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>I</mi><mn>1</mn></msub><mo>=</mo><mfrac><mn>3</mn><mn>2000</mn></mfrac><mo> </mo><mi mathvariant=\"normal\">A</mi></math></p><p>Therefore, from equation (1), it follows that</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><msub><mi>I</mi><mi>z</mi></msub></mtd><mtd><mo>=</mo></mtd><mtd><mfrac><mrow><mn>7</mn><mo>-</mo><mn>1</mn><mo>.</mo><mn>5</mn></mrow><mn>1000</mn></mfrac><mo> </mo><mi mathvariant=\"normal\">A</mi></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>5</mn><mo>.</mo><mn>5</mn><mo> </mo><mi>mA</mi></mtd></mtr></mtable></math></p>","type":"mcq","source":"JEE Main 2024 (29 Jan Shift 1)","image":null},{"id":43643,"subject":"Physics","chapter":"Semiconductors","question":"","options":["$Y=\\overline{A+B}$","$Y=\\overline{A \\cdot B}$","$Y=A \\cdot B$","$Y=\\bar{A}$"],"answer":0,"solution":"NOR gate is the combination of NOT and OR gate. Boolean expression for NOR gate is $Y=\\overline{A+B}$","type":"mcq","source":"JEE Main 2012 (19 May Online)","image":null},{"id":43578,"subject":"Physics","chapter":"Semiconductors","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>From the formula of current gain,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">&#946;</mi><mo>=</mo><msub><mfenced><mfrac><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">C</mi></msub><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">B</mi></msub></mfrac></mfenced><mrow><msub><mi mathvariant=\"normal\">V</mi><mi>CE</mi></msub><mo>=</mo><mn>10</mn></mrow></msub></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">C</mi></msub><mo>=</mo><mfenced><mrow><mn>4</mn><mo>.</mo><mn>5</mn><mo>-</mo><mn>3</mn></mrow></mfenced><mo>&#160;</mo><mi>mA</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">C</mi></msub><mo>=</mo><mn>1</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi>mA</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">C</mi></msub><mo>=</mo><mn>1</mn><mo>.</mo><mn>5</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup><mo>&#160;</mo><mi mathvariant=\"normal\">A</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">B</mi></msub><mo>=</mo><mfenced><mrow><mn>30</mn><mo>-</mo><mn>20</mn></mrow></mfenced><mo>&#160;</mo><mi>&#956;A</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">B</mi></msub><mo>=</mo><mn>10</mn><mo>&#160;</mo><mi>&#956;A</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">B</mi></msub><mo>=</mo><mn>10</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>6</mn></mrow></msup><mo>&#160;</mo><mi mathvariant=\"normal\">A</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">B</mi></msub><mo>=</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>5</mn></mrow></msup><mo>&#160;</mo><mi mathvariant=\"normal\">A</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi mathvariant=\"normal\">&#946;</mi><mo>=</mo><msub><mfenced><mfrac><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">C</mi></msub><msub><mi>&#916;i</mi><mi mathvariant=\"normal\">B</mi></msub></mfrac></mfenced><mrow><msub><mi mathvariant=\"normal\">V</mi><mi>CE</mi></msub><mo>=</mo><mn>10</mn></mrow></msub><mo>=</mo><mfenced><mfrac><mrow><mn>1</mn><mo>.</mo><mn>5</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup></mrow><msup><mn>10</mn><mrow><mo>-</mo><mn>5</mn></mrow></msup></mfrac></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi mathvariant=\"normal\">&#946;</mi><mo>=</mo><mfenced><mrow><mn>1</mn><mo>.</mo><mn>5</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup><mo>&#215;</mo><msup><mn>10</mn><mn>5</mn></msup></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi mathvariant=\"normal\">&#946;</mi><mo>=</mo><mn>150</mn></math></p>","type":"mcq","source":"JEE Main 2020 (06 Sep Shift 2)","image":null},{"id":43493,"subject":"Physics","chapter":"Semiconductors","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>NAND</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>AND</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>NOR</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>OR</mi></math>"],"answer":2,"solution":"<blockquote><p>Let&#39;s assume that when the path is short, the state is called state <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math>&nbsp;and when it is open, the state is called state <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math>.</p><p style=\"text-align: justify;\"><img src=\"https://.app/pyq/jee_main/af514519-5760-42d8-b239-07f01eb186d0.png\" style=\"width: 300px; height: 251px;\" /></p><p>Depending up on whether the path is short or not&nbsp;in the circuit, the following table can be obtained:</p><table border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 500px;\">\t<tbody>\t\t<tr>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">A</mi></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">B</mi></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Out</mi></math></td>\t\t</tr>\t\t<tr>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t</tr>\t\t<tr>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t</tr>\t\t<tr>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t</tr>\t\t<tr>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math></td>\t\t\t<td style=\"text-align: center;\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn></math></td>\t\t</tr>\t</tbody></table><p>The above table is similar to the truth table corresponding to&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>NOR</mi></math>&nbsp;gate. Hence, the circuit indicates a&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>NOR</mi></math>&nbsp;logic gate.</p></blockquote>","type":"mcq","source":"JEE Main 2023 (06 Apr Shift 1)","image":null}]