x-2 x-2 k\\right\\}}{(x-2)^2}=5 \\\\\n\\Rightarrow & \\lim _{x \\rightarrow 2} \\frac{\\tan (x-2)\\{x(x-2)+k(x-2)\\}}{(x-2) \\times(x-2)}=5 \\\\\n\\Rightarrow \\lim _{x \\rightarrow 2}\\left(\\frac{\\tan (x-2)}{(x-2)}\\right) \\times \\lim _{x \\rightarrow 2}\\left(\\frac{(k+x)(x-2)}{(x-2)}\\right)=5 \\\\\n\\Rightarrow & 1 \\times \\lim _{x \\rightarrow 2}(k+x)=5 \\\\\n&\\left\\{\\because \\lim _{h \\rightarrow 0} \\frac{\\tan h}{h}=1\\right\\} \\\\\n& \\text { or } k+2=5 \\\\\n\\Rightarrow k=3\n\\end{aligned}\n$$","type":"mcq","source":"JEE Main 2014 (11 Apr Online)","image":null},{"id":35757,"subject":"Mathematics","chapter":"Limits","q":"If&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#945;</mi></math> is the positive root of the equation,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>p</mi><mfenced><mi>x</mi></mfenced><mo>=</mo><msup><mi>x</mi><mn>2</mn></msup><mo>&#8722;</mo><mi>x</mi><mo>&#8722;</mo><mn>2</mn><mo>=</mo><mn>0</mn></math>,&nbsp;then <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><munder><mi>lim</mi><mrow><mi>x</mi><mo>&#8594;</mo><msup><mi>&#945;</mi><mo>+</mo></msup></mrow></munder><mfrac><msqrt><mn>1</mn><mo>&#8722;</mo><mi>cos</mi><mi>p</mi><mfenced><mi>x</mi></mfenced></msqrt><mrow><mi>x</mi><mo>+</mo><mi>&#945;</mi><mo>&#8722;</mo><mn>4</mn></mrow></mfrac></math>is equal to","question":"If&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#945;</mi></math> is the positive root of the equation,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>p</mi><mfenced><mi>x</mi></mfenced><mo>=</mo><msup><mi>x</mi><mn>2</mn></msup><mo>&#8722;</mo><mi>x</mi><mo>&#8722;</mo><mn>2</mn><mo>=</mo><mn>0</mn></math>,&nbsp;then <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><munder><mi>lim</mi><mrow><mi>x</mi><mo>&#8594;</mo><msup><mi>&#945;</mi><mo>+</mo></msup></mrow></munder><mfrac><msqrt><mn>1</mn><mo>&#8722;</mo><mi>cos</mi><mi>p</mi><mfenced><mi>x</mi></mfenced></msqrt><mrow><mi>x</mi><mo>+</mo><