/mi><mi mathvariant=\"normal\">d</mi><mi>&#952;</mi><mo>=</mo><msubsup><mfenced close=\"]\" open=\"[\"><mrow><mo>-</mo><mi>cos</mi><mi>&#952;</mi></mrow></mfenced><mn>0</mn><mfrac><mi>&#960;</mi><mn>2</mn></mfrac></msubsup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mo>-</mo><mfenced><mrow><mn>0</mn><mo>-</mo><mn>1</mn></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mn>1</mn></math></p>","type":"mcq","source":"JEE Main 2021 (20 Jul Shift 2)","image":null},{"id":33927,"subject":"Mathematics","chapter":"Complex Number","question":"","options":["<math><mo>-</mo><mn>2</mn></math>","<math><mo>-</mo><mn>4</mn></math>","<math><mo>-</mo><mn>5</mn></math>","<math><mo>-</mo><mn>1</mn></math>"],"answer":1,"solution":"<p>Let,&nbsp;<math><mrow><mi>z</mi><mo>=</mo><mi>r</mi><mo stretchy=\"false\">(</mo><mtext>cos</mtext><mi>&#952;</mi><mo>+</mo><mi>i</mi><mtext>sin</mtext><mi>&#952;</mi><mo stretchy=\"false\">)</mo></mrow> </math><br /><br /><math> <mrow> <msup> <mi>z</mi> <mn>5</mn> </msup> <mo>=</mo><msup> <mi>r</mi> <mn>5</mn> </msup> <mo stretchy=\"false\">(</mo><mtext>cos</mtext><mn>5</mn><mi>&#952;</mi><mo>+</mo><mi>i</mi><mtext>sin</mtext><mn>5</mn><mi>&#952;</mi><mo stretchy=\"false\">)</mo></mrow> </math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>I</mi><mi>m</mi><mfenced><msup><mi>z</mi><mn>5</mn></msup></mfenced><mo>=</mo><msup><mi>r</mi><mn>5</mn></msup><mi>sin</mi><mn>5</mn><mi>&#952;</mi></math><br /><br />and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mfenced separators=\"|\"><mrow><mi>I</mi><mi>m</mi><mi>&#160;</mi><mi>z</mi></mrow></mfenced><mn>5</mn></msup><mo>=</mo><msup><mi>r</mi><mn>5</mn></msup><msup><mi>sin</mi><mn>5</mn></msup><mi>&#952;</mi></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mi>I</mi><mi>m</mi><mi>&#160;</mi><mo>(</mo><msup><mi>z</mi><mn>5</mn></msup><mo>)</mo></mrow><msup><mfenced separators=\"|\"><mrow><mi>I</mi><mi>m</mi><mi>&#160;</mi><mi>z</mi></mrow></mfenced><mn>5</mn></msup></mfrac><mo>=</mo><mi>&#160;</mi><mfrac><mrow><mi>sin</mi><mn>5</mn><mi>&#952;</mi></mrow><mrow><msup><mi>sin</mi><mn>5</mn></msup><mi>&#952;</mi></mrow></mfrac><mo>=</mo><mi>A&#160;</mi></math>(Let)<br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mrow><mi>d</mi><mi>A</mi></mrow><mrow><mi>d</mi><mi>&#952;</mi></mrow></mfrac><mo>=</mo><mfrac><mrow><mn>5</mn><msup><mi>sin</mi><mn>5</mn></msup><mi>&#952;</mi><mi>cos</mi><mn>5</mn><mi>&#952;</mi><mo>-</mo><mn>5</mn><mi>sin</mi><mn>5</mn><mi>&#952;</mi><msup><mi>sin</mi><mn>4</mn></msup><mi>&#952;</mi><mi>cos</mi><mi>&#952;</mi></mrow><msup><mfenced separators=\"|\"><mrow><msup><mi>sin</mi><mn>5</mn></msup><mi>&#952;</mi></mrow></mfenced><mn>2</mn></msup></mfrac></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mrow><mi>d</mi><mi>A</mi></mrow><mrow><mi>d</mi><mi>&#952;</mi></mrow></mfrac><mo>=</mo><mfrac><mrow><mn>5</mn><msup><mi>sin</mi><mn>4</mn></msup><mi>&#952;</mi><mfenced separators=\"|\"><mrow><mi>sin</mi><mi>&#952;</mi><mi>cos</mi><mn>5</mn><mi>&#952;</mi><mo>-</mo><mi>sin</mi><mn>5</mn><mi>&#952;</mi><mi>cos</mi><mi>&#952;</mi></mrow></mfenced></mrow><mrow><msup><mi>sin</mi><mn>10</mn></msup><mi>&#952;</mi></mrow></mfrac></math><br /><br /><math> <mrow> <mo>&#8658;</mo><mfrac> <mrow> <mi>d</mi><mi>A</mi></mrow> <mrow> <mi>d</mi><mi>&#952;</mi></mrow> </mfrac> <mo>=</mo><mfrac> <mn>5</mn> <mrow> <msup> <mrow> <mi>sin</mi></mrow> <mn>6</mn> </msup> <mi>&#952;</mi></mrow> </mfrac> <mfenced close=\"]\" open=\"[\"> <mrow> <mi>sin</mi><mfenced> <mrow> <mo>&#8722;</mo><mn>4</mn><mi>&#952;</mi></mrow> </mfenced></mrow> </mfenced><mo>=</mo><mn>0</mn></mrow> </math><br /><br /><math><mo>&#8658;</mo><mi>&#952;</mi><mo>=</mo><mfrac><mi>&#960;</mi><mn>4</mn></mfrac></math><br /><br />The minimum value of <math><mi>A</mi></math> will be at &nbsp;<math><mi>&#952;</mi><mo>=</mo><mfrac><mi>&#960;</mi><mn>4</mn></mfrac><mo>.</mo></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>A</mi><mo>=</mo><mfrac><mrow><mi>sin</mi><mn>5</mn><mfrac><mi>&#960;</mi><mn>4</mn></mfrac></mrow><msup><mfenced separators=\"|\"><mrow><mi>sin</mi><mfrac><mi>&#960;</mi><mn>4</mn></mfrac></mrow></mfenced><mn>5</mn></msup></mfrac></math><br /><math><mo>=</mo><mfrac><mfrac><mrow><mo>-</mo><mn>1</mn></mrow><msqrt><mn>2</mn></msqrt></mfrac><msup><mfenced separators=\"|\"><mfrac><mn>1</mn><msqrt><mn>2</mn></msqrt></mfrac></mfenced><mn>5</mn></msup></mfrac></math><br /><br /><math><mo>=</mo><mo>-</mo><msup><mfenced separators=\"|\"><msqrt><mn>2</mn></msqrt></mfenced><mn>4</mn></msup><mo>=</mo><mo>-</mo><mn>4</mn></math></p>","type":"mcq","source":"JEE Main 2015 (11 Apr Online)","image":null},{"id":33943,"subject":"Mathematics","chapter":"Complex Number","question":"","options":["$2|z|^2$","$1 / 2|z|^2$","$4|z|^2$","$|z|^2$"],"answer":1,"solution":"Vertices of triangle in complex form is $z, i z, z+i z$\nIn cartesian form vertices are $(x, y),(-y, x)$ and $(x-y, x+y)$\n$$\n\\begin{aligned}\n& \\therefore \\text { Area of triangle }=\\frac{1}{2}\\left|\\begin{array}{ccc}\nx & y & 1 \\\\\n-y & x & 1 \\\\\nx-y & x+y & 1\n\\end{array}\\right| \\\\\n& =\\frac{1}{2}[x(x-x-y)-y(-y-x+y)+1 \\\\\n& \\left.\\left(-y x-y^2-x^2+x y\\right)\\right]\n\\end{aligned}\n$$\n$$\n\\begin{aligned}\n& =\\frac{1}{2}\\left[-x y+x y-y^2-x^2\\right]=\\frac{1}{2}\\left(x^2+y^2\\right) \\\\\n& (\\because \\text { Area can not be negative }) \\\\\n& =\\frac{1}{2}|z|^2 \\quad\\left(\\because z=x+i y,|z|^2=x^2+y^2\\right)\n\\end{aligned}\n$$","type":"mcq","source":"JEE Main 2012 (12 May Online)","image":null},{"id":33778,"subject":"Mathematics","chapter":"Complex Number","question":"","options":["$50$","$100$","$\\frac{81}{25}$","$\\frac{121}{25}$"],"answer":1,"solution":"Let $z=x+i y \\Rightarrow \\bar{z}=x-i y$\n$\\begin{aligned}\n& 3|\\bar{z}-i|=1|2 \\bar{z}+i| \\\\\n& =3 \\mid(x-(y+1) i|=|2 x+i(1-2 y)| \\\\\n& =3 \\sqrt{x^2+(y+1)^2}=\\sqrt{(2 x)^2+(1-2 y)^2} \\\\\n& =9\\left(x^2+y^2+2 y+1\\right)=4 x^2+4 y^2-4 y+1 \\\\\n& \\Rightarrow 5 x^2+5 y^2+22 y+8=0 \\\\\n& \\Rightarrow \\text { Centre } \\equiv\\left(0,-\\frac{11}{5}\\right)\n\\end{aligned}$\n<img src=\"https://.app/pyq/jee_main/ov5I9A9--o5t07Qli6YN7R1n4I2juRo63UKaz7HyPMQ.original.fullsize.png\"><br>\nArea of $\\Delta$\n$=\\frac{1}{2}|\\alpha|\\left|\\frac{-11}{5}\\right|=11$\n$\\begin{aligned} & \\Rightarrow \\quad|\\alpha|=10 \\\\ & \\Rightarrow \\quad \\alpha^2=100\\end{aligned}$","type":"mcq","source":"JEE Main 2025 (23 Jan Shift 1)","image":null},{"id":33816,"subject":"Mathematics","chapter":"Complex Number","question":"","options":["A","B","C","D"],"answer":0,"solution":"<blockquote><p>Given,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#945;</mi><mo>,</mo><mo>&#160;</mo><mi>&#946;</mi><mo>,</mo><mo>&#160;</mo><mi>z</mi><mo>&#8712;</mo><mi mathvariant=\"normal\">&#8450;</mi></math>&nbsp;and&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#955;</mi><mo>&#62;</mo><mn>1</mn></math>,</p><p>And&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mi>&#955;</mi><mo>-</mo><mn>1</mn></msqrt></math>&nbsp;is the radius of the circle&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>z</mi><mo>-</mo><mi>&#945;</mi></mrow></mfenced><mn>2</mn></msup><mo>+</mo><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>z</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></msup><mo>=</mo><mn>2</mn><mi>&#955;</mi></math>&nbsp;</p><p>Now we know that equation of circle is given by,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>z</mi><mo>-</mo><msub><mi>z</mi><mn>1</mn></msub></mrow></mfenced><mn>2</mn></msup><mo>+</mo><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>z</mi><mo>-</mo><msub><mi>z</mi><mn>2</mn></msub></mrow></mfenced><mn>2</mn></msup><mo>=</mo><msup><mfenced close=\"|\" open=\"|\"><mrow><msub><mi>z</mi><mn>1</mn></msub><mo>-</mo><msub><mi>z</mi><mn>2</mn></msub></mrow></mfenced><mn>2</mn></msup></math>, where radius is given by&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>r</mi><mo>=</mo><mfrac><mfenced close=\"|\" open=\"|\"><mrow><msub><mi>z</mi><mn>1</mn></msub><mo>-</mo><msub><mi>z</mi><mn>2</mn></msub></mrow></mfenced><mn>2</mn></mfrac></math>,</p><p>On comparing with&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>z</mi><mo>-</mo><mi>&#945;</mi></mrow></mfenced><mn>2</mn></msup><mo>+</mo><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>z</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></msup><mo>=</mo><mn>2</mn><mi>&#955;</mi></math>, we get</p><p>Radius&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mfenced close=\"|\" open=\"|\"><mrow><msub><mi>z</mi><mn>1</mn></msub><mo>-</mo><msub><mi>z</mi><mn>2</mn></msub></mrow></mfenced><mn>2</mn></mfrac><mo>=</mo><mfrac><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></mfrac></math>&nbsp;and&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></msup><mo>=</mo><mn>2</mn><mi>&#955;</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></mfrac><mo>=</mo><msqrt><mi>&#955;</mi><mo>-</mo><mn>1</mn></msqrt><mo>&#160;</mo><mfenced><mtext>given</mtext></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mo>=</mo><mn>2</mn><msqrt><mi>&#955;</mi><mo>-</mo><mn>1</mn></msqrt></math>&nbsp;</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></msup><mo>=</mo><mn>4</mn><mfenced><mrow><mi>&#955;</mi><mo>-</mo><mn>1</mn></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mn>2</mn><mi>&#955;</mi><mo>=</mo><mn>4</mn><mfenced><mrow><mi>&#955;</mi><mo>-</mo><mn>1</mn></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>&#955;</mi><mo>=</mo><mn>2</mn></math></p><p>Hence,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mn>2</mn></msup><mo>=</mo><mn>4</mn><mo>&#8658;</mo><mfenced close=\"|\" open=\"|\"><mrow><mi>&#945;</mi><mo>-</mo><mi>&#946;</mi></mrow></mfenced><mo>=</mo><mn>2</mn></math></p></blockquote>","type":"mcq","source":"JEE Main 2023 (06 Apr Shift 2)","image":null},{"id":33953,"subject":"Mathematics","chapter":"Complex Number","question":"","options":["$-1,-1+2 \\omega,-1-2 \\omega^2$","$-1,-1,-1$","$-1,1-2 \\omega, 1-2 \\omega^2$","$-1,1+2 \\omega, 1+2 \\omega^2$"],"answer":2,"solution":"$(x-1)^3+8=0 \\Rightarrow(x-1)=(-2)(1)^{1 / 3}$ $\\Rightarrow x-1=-2$ or $-2 \\omega$ or $-2 \\omega^2$ or $n=-1$ or $1-2 \\omega$ or $1-2 \\omega^2$.","type":"mcq","source":"JEE Main 2005","image":null}]