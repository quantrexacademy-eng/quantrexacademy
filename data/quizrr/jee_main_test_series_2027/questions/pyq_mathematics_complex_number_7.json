<mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced></mrow></mfrac></math></p><p>Hence,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>R</mi><mi>e</mi><mfenced><mi>z</mi></mfenced><mo>=</mo><mfrac><mrow><mn>2</mn><msup><mi>sin</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced></mrow><mrow><mn>4</mn><msup><mi>sin</mi><mn>4</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced><mo>+</mo><mn>16</mn><msup><mi>sin</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced><msup><mi>cos</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced></mrow></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mn>1</mn><mrow><mn>2</mn><msup><mi>sin</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced><mo>+</mo><mn>8</mn><msup><mi>cos</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced></mrow></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>5</mn></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mn>1</mn><mrow><mn>2</mn><msup><mi>sin</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced><mo>+</mo><mn>8</mn><msup><mi>cos</mi><mn>2</mn></msup><mfenced><mstyle displaystyle=\"true\"><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mstyle></mfenced></mrow></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>5</mn></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msup><mi>sin</mi><mn>2</mn></msup><mfenced><mfrac><mi>&#952;</mi><mn>2</mn></mfrac></mfenced><mo>+</mo><mn>4</mn><msup><mi>cos</mi><mn>2</mn></