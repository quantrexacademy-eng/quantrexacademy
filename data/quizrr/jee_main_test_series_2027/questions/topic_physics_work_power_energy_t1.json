[{"id":44647,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>-</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mi>sin</mi><mi>&#952;</mi><mover><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>+</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mi>cos</mi><mi>&#952;</mi><mover><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>-</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mi>cos</mi><mi>&#952;</mi><mover><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>+</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mi>sin</mi><mi>&#952;</mi><mover><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>-</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mi>cos</mi><mi>&#952;</mi><mover><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>-</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mi>sin</mi><mi>&#952;</mi><mover><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>-</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mover><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>+</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mover><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></math>"],"answer":2,"solution":"<p><img src=\"https://.app/pyq/jee_main/8d87383a-d7c1-4c29-b9bc-af226b416c73-image.png\" style=\"width: 150px; height: 141px;\" /></p><p>Acceleration of a particle in uniform circular motion&nbsp;is directed towards the centre of the circle and its magnitude is&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac></math>. The radius vector is<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover accent=\"true\"><mi>r</mi><mo>&#8594;</mo></mover><mo>=</mo><mi>R</mi><mi>cos</mi><mi>&#952;</mi><mover accent=\"true\"><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>+</mo><mi>R</mi><mi>sin</mi><mi>&#952;</mi><mover accent=\"true\"><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></math></p><p>Therefore,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover accent=\"true\"><mi>a</mi><mo>&#8594;</mo></mover><mo>=</mo><mo>-</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mover><mi mathvariant=\"normal\">r</mi><mo>^</mo></mover><mo>=</mo><mfrac><msup><mi>v</mi><mn>2</mn></msup><mi>R</mi></mfrac><mfenced><mrow><mo>&#8722;</mo><mi>cos</mi><mi>&#952;</mi><mover accent=\"true\"><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>&#8722;</mo><mi>sin</mi><mi>&#952;</mi><mover accent=\"true\"><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></mrow></mfenced></math></p>","type":"mcq","source":"JEE Main 2022 (25 Jun Shift 2)","image":null},{"id":44575,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["\\(\\frac{n^2}{n^2+4}\\)","\\(\\frac{n^2+4}{n^2}\\)","\\(\\frac{n+4}{n}\\)","\\(\\frac{n}{n+4}\\)"],"answer":1,"solution":"<img src=\"https://.app/pyq/jee_main/5gANTm719Psh3x7WpIkZIB3lqxm6kpjaozDeKZdBug8.original.fullsize.png\"><br>\n$\\begin{aligned} & v_0=\\sqrt{v^2+2 g(2 R)} \\\\ & v_0=\\sqrt{n^2 g R+4 g R} \\\\ & \\therefore \\quad \\frac{k_{\\text {bottom }}}{k_{\\text {top }}}=\\frac{v_0^2}{v^2}=\\frac{n^2+4}{n^2}\\end{aligned}$","type":"mcq","source":"JEE Main 2025 (29 Jan Shift 1)","image":null},{"id":44719,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$\\frac{\\mathrm{R}_2}{\\mathrm{R}_1}$","$\\left(\\frac{\\mathrm{R}_1}{\\mathrm{R}_2}\\right)^2$","1","$\\frac{\\mathrm{R}_1}{\\mathrm{R}_2}$"],"answer":3,"solution":"$\\frac{\\mathrm{F}_1}{\\mathrm{~F}_2}=\\frac{\\mathrm{R}_1 \\omega^2}{\\mathrm{R}_2 \\omega^2}=\\frac{\\mathrm{R}_1}{\\mathrm{R}_2}$","type":"mcq","source":"JEE Main 2005","image":null},{"id":44693,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mn>10</mn><mrow><mo>&#8722;</mo><mn>1</mn></mrow></msup><mo>&#160;</mo><mi>kg</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">m</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mn>10</mn><mrow><mo>&#8722;</mo><mn>3</mn></mrow></msup><mo>&#160;</mo><mi>kg</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">m</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mn>10</mn><mrow><mo>&#8722;</mo><mn>3</mn></mrow></msup><mo>&#160;</mo><mi>kg</mi><mo>&#160;</mo><msup><mi>s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mn>10</mn><mrow><mo>&#8722;</mo><mn>4</mn></mrow></msup><mo>&#160;</mo><mi>kg</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">m</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>"],"answer":3,"solution":"After <math> <mrow> <mn>10</mn><mtext>&#8196;</mtext><mtext>sec,</mtext></mrow> </math> <math><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mi>m</mi><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup><mo>=</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>8</mn></mrow></mfrac><mi>m</mi><msubsup><mrow><mi>v</mi></mrow><mrow><mn>0</mn></mrow><mrow><mn>2</mn></mrow></msubsup></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>v</mi><mo>=</mo><mfrac><msub><mi>v</mi><mn>0</mn></msub><mn>2</mn></mfrac><mo>=</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math><br />Acceleration,&nbsp;<math> <mrow> <mi>a</mi><mo>=</mo><mo>&#8722;</mo><mfrac> <mrow> <mi>k</mi><msup> <mi>v</mi> <mn>2</mn> </msup> </mrow> <mi>m</mi> </mfrac> </mrow> </math><br /><math> <mrow> <mo>&#8658;</mo><mo>&#160;</mo><mfrac> <mrow> <mi>d</mi><mi>v</mi></mrow> <mrow> <mi>d</mi><mi>t</mi></mrow> </mfrac> <mo>=</mo><mo>&#8722;</mo><mfrac> <mrow> <mi>k</mi><msup> <mi>v</mi> <mn>2</mn> </msup> </mrow> <mi>m</mi> </mfrac> </mrow> </math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mo>&#160;</mo><munderover><mo>&#8747;</mo><mn>10</mn><mn>5</mn></munderover><mfrac><mrow><mi>d</mi><mi>v</mi></mrow><msup><mi>v</mi><mn>2</mn></msup></mfrac><mo>=</mo><mo>&#8722;</mo><mfrac><mi>k</mi><mi>m</mi></mfrac><mo>&#160;</mo><munderover><mo>&#8747;</mo><mn>0</mn><mn>10</mn></munderover><mi>d</mi><mi>t</mi></math><br /><math><mo>-</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>5</mn></mrow></mfrac><mo>+</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>10</mn></mrow></mfrac><mo>=</mo><mfrac><mrow><mo>-</mo><mi>k</mi></mrow><mrow><msup><mrow><mn>10</mn></mrow><mrow><mo>-</mo><mn>2</mn></mrow></msup></mrow></mfrac><mo>&#215;</mo><mn>10</mn></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>k</mi><mo>=</mo><msup><mn>10</mn><mrow><mo>&#8722;</mo><mn>4</mn></mrow></msup><mo>&#160;</mo><mi>kg</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">m</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","type":"mcq","source":"JEE Main 2017 (02 Apr)","image":null},{"id":44681,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math><mfrac><mrow><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mi>g</mi></mrow></mfrac></math>","<math><mfrac><mrow><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>2</mn><mi>g</mi></mrow></mfrac></math>","<math><mfrac><mrow><mn>2</mn><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>5</mn><mi>g</mi></mrow></mfrac></math>","<math><mfrac><mrow><mn>2</mn><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>7</mn><mi>g</mi></mrow></mfrac></math>"],"answer":2,"solution":"From conservation of linear momentum, <br/><img src=\"https://.app/pyq/jee_main/f2eed996-960d-4254-8307-edae26bc7b82-image11.png\"> <br/><math><mi>m</mi><mi>v</mi><mo>=</mo><mfenced separators=\"|\"><mrow><mn>4</mn><mi>m</mi><mo>+</mo><mi>m</mi></mrow></mfenced><msub><mrow><mi>v</mi></mrow><mrow><mi>f</mi></mrow></msub></math>  <br/><math><msub><mrow><mi>v</mi></mrow><mrow><mi>f</mi></mrow></msub><mo>=</mo><mfrac><mrow><mi>v</mi></mrow><mrow><mn>5</mn></mrow></mfrac></math>  <br/>From conservation of mechanical energy, <br/><math><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mi>m</mi><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup><mo>=</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mfenced separators=\"|\"><mrow><mn>4</mn><mi>m</mi><mo>+</mo><mi>m</mi></mrow></mfenced><msubsup><mrow><mi>v</mi></mrow><mrow><mi>f</mi></mrow><mrow><mn>2</mn></mrow></msubsup><mo>+</mo><mi>m</mi><mi>g</mi><mi>h</mi></math>  <br/><math><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup><mo>=</mo><mn>5</mn><msubsup><mrow><mi>v</mi></mrow><mrow><mi>f</mi></mrow><mrow><mn>2</mn></mrow></msubsup><mo>+</mo><mn>2</mn><mi>g</mi><mi>h</mi></math>  <br/><math><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup><mo>=</mo><mn>5</mn><mo>×</mo><msup><mrow><mfenced separators=\"|\"><mrow><mfrac><mrow><mi>v</mi></mrow><mrow><mn>5</mn></mrow></mfrac></mrow></mfenced></mrow><mrow><mn>2</mn></mrow></msup><mo>+</mo><mn>2</mn><mi>g</mi><mi>h</mi></math>  <br/><math><mi>h</mi><mo>=</mo><mfrac><mrow><mn>2</mn><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>5</mn><mi>g</mi></mrow></mfrac></math>","type":"mcq","source":"JEE Main 2019 (09 Apr Shift 2)","image":null},{"id":44601,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>4200</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>3900</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>4000</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>4500</mn></math>"],"answer":2,"solution":"<p>Given <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>m</mi><mo>=</mo><mn>100</mn><mo> </mo><mi>kg</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>s</mi><mo>=</mo><mn>10</mn><mo> </mo><mi mathvariant=\"normal\">m</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>μ</mi><mo>=</mo><mn>0</mn><mo>.</mo><mn>4</mn></math></p><p>The frictional force is given by</p><p> <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>f</mi></mtd><mtd><mo>=</mo></mtd><mtd><mi>μ</mi><mi>m</mi><mi>g</mi></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>0</mn><mo>.</mo><mn>4</mn><mo>×</mo><mn>100</mn><mo>×</mo><mn>10</mn></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>400</mn><mo> </mo><mi mathvariant=\"normal\">N</mi></mtd></mtr></mtable></math></p><p>So, the work done by the force can be calculated as follows:</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>W</mi></mtd><mtd><mo>=</mo></mtd><mtd><mi>f</mi><mo>×</mo><mi>s</mi></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>400</mn><mo>×</mo><mn>10</mn></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>4000</mn><mo> </mo><mi mathvariant=\"normal\">J</mi></mtd></mtr></mtable></math></p>","type":"mcq","source":"JEE Main 2024 (29 Jan Shift 1)","image":null},{"id":44685,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>9</mn><mi>&#160;</mi><mi mathvariant=\"normal\">J</mi></math>.","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>15</mn><mi>&#160;</mi><mi mathvariant=\"normal\">J</mi></math>.","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>12</mn><mi>&#160;</mi><mi mathvariant=\"normal\">J</mi></math>.","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>10</mn><mi mathvariant=\"normal\">&#160;</mi><mi mathvariant=\"normal\">J</mi></math>."],"answer":1,"solution":"Work done by the force,<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover><mi>F</mi><mo>&#8594;</mo></mover><mo>.</mo><mover><mi>s</mi><mo>&#8594;</mo></mover><mo>=</mo><mfenced separators=\"|\"><mrow><mn>3</mn><mover><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover><mo>+</mo><mn>12</mn><mover><mi mathvariant=\"normal\">j</mi><mo>^</mo></mover></mrow></mfenced><mo>&#8901;</mo><mfenced separators=\"|\"><mrow><mn>4</mn><mover><mi mathvariant=\"normal\">i</mi><mo>^</mo></mover></mrow></mfenced><mspace linebreak=\"newline\"></mspace><mo>=</mo><mn>12</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math><br /><br />By work energy theorem, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>W</mi><mi>total</mi></msub><mo>=</mo><mo>&#8710;</mo><mi>K</mi></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>12</mn><mi>&#160;</mi><mi mathvariant=\"normal\">J</mi><mo>=</mo><msub><mi>K</mi><mi mathvariant=\"normal\">f</mi></msub><mo>-</mo><msub><mi>K</mi><mi mathvariant=\"normal\">i</mi></msub><mspace linebreak=\"newline\"/><mn>12</mn><mo>+</mo><msub><mi>K</mi><mi mathvariant=\"normal\">i</mi></msub><mo>=</mo><msub><mi>K</mi><mi mathvariant=\"normal\">f</mi></msub></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8756;</mo><msub><mi>K</mi><mi mathvariant=\"normal\">f</mi></msub><mo>=</mo><mn>12</mn><mo>+</mo><mn>3</mn><mo>=</mo><mn>15</mn><mi>&#160;</mi><mi mathvariant=\"normal\">J</mi></math>","type":"mcq","source":"JEE Main 2019 (10 Jan Shift 2)","image":null},{"id":44612,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>The formula to calculate the work done by a variable force is given by</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>W</mi><mo>=</mo><msubsup><mo>&#8747;</mo><msub><mi>x</mi><mn>1</mn></msub><msub><mi>x</mi><mn>2</mn></msub></msubsup><mi>F</mi><mi>d</mi><mi>x</mi><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>1</mn></mfenced></math></p><p>Substitute the values of the known parameters into equation (1) to calculate the required work done.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>W</mi></mtd><mtd><mo>=</mo></mtd><mtd><msubsup><mo>&#8747;</mo><mn>0</mn><mn>4</mn></msubsup><mo>&#8202;</mo><mo>(</mo><mn>2</mn><mo>+</mo><mn>3</mn><mi>x</mi><mo>)</mo><mi>d</mi><mi>x</mi></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><msubsup><mfenced close=\"]\" open=\"[\" separators=\"|\"><mrow><mn>2</mn><mi>x</mi><mo>+</mo><mfrac><mn>3</mn><mn>2</mn></mfrac><msup><mi>x</mi><mn>2</mn></msup></mrow></mfenced><mn>0</mn><mn>4</mn></msubsup></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mo>[</mo><mn>8</mn><mo>+</mo><mn>24</mn><mo>]</mo><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>32</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></mtd></mtr></mtable></math></p>","type":"mcq","source":"JEE Main 2023 (11 Apr Shift 1)","image":null},{"id":44600,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>3</mn><mo>:</mo><mn>2</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>5</mn><mo>:</mo><mn>1</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>:</mo><mn>5</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn><mo>:</mo><mn>5</mn></math>"],"answer":1,"solution":"<p>The velocity given is minimum, just enough to complete verticle circle. At the top most point, tension of the string will be zero and gravitational force will provide the required centripetal force.</p><p>Therefore, </p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>m</mi><mi>g</mi><mo>=</mo><mfrac><mrow><mi>m</mi><msup><mfenced><msub><mi>V</mi><mi>H</mi></msub></mfenced><mn>2</mn></msup></mrow><mi>L</mi></mfrac><mspace linebreak=\"newline\"></mspace><mo>⇒</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mfenced><msub><mi>V</mi><mi>H</mi></msub></mfenced><mn>2</mn></msup><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>g</mi><mi>L</mi></math></p><p>Apply energy conservation between point <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>A</mi></math> and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>B</mi></math>, we get</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msubsup><mi>V</mi><mi>L</mi><mn>2</mn></msubsup><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msubsup><mi>V</mi><mi>H</mi><mn>2</mn></msubsup><mo>+</mo><mi>m</mi><mi>g</mi><mo>(</mo><mn>2</mn><mo> </mo><mi>L</mi><mo>)</mo></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>⇒</mo><msub><mi>V</mi><mi>L</mi></msub><mo>=</mo><msqrt><mn>5</mn><mi>g</mi><mi>L</mi></msqrt></math></p><p>Also, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>V</mi><mi>H</mi></msub><mo>=</mo><msqrt><mi>g</mi><mi>L</mi></msqrt></math></p><p>Required ratio, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mo>(</mo><mi>K</mi><mo>.</mo><mi>E</mi><msub><mo>)</mo><mi>A</mi></msub></mrow><mrow><mo>(</mo><mi>K</mi><mo>.</mo><mi>E</mi><msub><mo>)</mo><mi>B</mi></msub></mrow></mfrac><mo>=</mo><mfrac><mrow><mfrac><mn>1</mn><mn>2</mn></mfrac><mo> </mo><mi>m</mi><mo>(</mo><msqrt><mn>5</mn><mi>g</mi><mi>L</mi></msqrt><msup><mo>)</mo><mn>2</mn></msup></mrow><mrow><mfrac><mn>1</mn><mn>2</mn></mfrac><mo> </mo><mi>m</mi><mo>(</mo><msqrt><mi>g</mi><mi>L</mi></msqrt><msup><mo>)</mo><mn>2</mn></msup></mrow></mfrac><mo>=</mo><mfrac><mn>5</mn><mn>1</mn></mfrac></math></p>","type":"mcq","source":"JEE Main 2024 (29 Jan Shift 2)","image":null},{"id":44714,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$\\frac{b^2}{2 a}$","$\\frac{b^2}{12 a}$","$\\frac{b^2}{4 a}$","$\\frac{b^2}{6 a}$"],"answer":2,"solution":"$$\n\\begin{aligned}\n& U(x)=\\frac{a}{x^{12}}-\\frac{b}{x^6} \\\\\n& U(x=\\infty)=0\n\\end{aligned}\n$$\nas, $\\quad \\mathrm{F}=-\\frac{\\mathrm{dU}}{\\mathrm{dx}}=-\\left[\\frac{12 \\mathrm{a}}{\\mathrm{x}^{13}}+\\frac{6 \\mathrm{~b}}{\\mathrm{x}^7}\\right]$ at equilibrium, $\\quad F=0$\n$\\begin{array}{ll}\\therefore & x^6=\\frac{2 a}{b} \\\\ \\therefore & U_{\\text {at equiltrium }}=\\frac{a}{\\left(\\frac{2 a}{b}\\right)^2}-\\frac{b}{\\left(\\frac{2 a}{b}\\right)}=\\frac{-b^2}{4 a} \\\\ \\therefore & D=\\left[U(x=\\infty)-U_{\\text {at equilibium }}\\right]=\\frac{b^2}{4 a}\\end{array}$","type":"mcq","source":"JEE Main 2010","image":null},{"id":44609,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>(</mo><mn>1000</mn><mo>&#177;</mo><mn>0</mn><mo>.</mo><mn>14</mn><mo>)</mo><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>(</mo><mn>500</mn><mo>&#177;</mo><mn>0</mn><mo>.</mo><mn>14</mn><mo>)</mo><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>(</mo><mn>500</mn><mo>&#177;</mo><mn>140</mn><mo>)</mo><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>(</mo><mn>1000</mn><mo>&#177;</mo><mn>140</mn><mo>)</mo><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>"],"answer":3,"solution":"<blockquote><p>The kinetic energy is given by,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>K</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup></math></p><p>Differentiating the above equation,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>d</mi><mi>K</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mo>(</mo><msup><mi>v</mi><mn>2</mn></msup><mi>d</mi><mi>m</mi><mo>+</mo><mn>2</mn><mi>m</mi><mi>v</mi><mi>d</mi><mi>v</mi><mo>)</mo></math></p><p>Dividing by&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>K</mi></math>,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mrow><mi>d</mi><mi>K</mi></mrow><mi>K</mi></mfrac><mo>=</mo><mfrac><mrow><mi>d</mi><mi>m</mi></mrow><mi>m</mi></mfrac><mo>+</mo><mfrac><mrow><mn>2</mn><mi>d</mi><mi>v</mi></mrow><mi>v</mi></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mrow><mi>d</mi><mi>K</mi></mrow><mn>1000</mn></mfrac><mo>=</mo><mfrac><mrow><mn>0</mn><mo>.</mo><mn>5</mn></mrow><mn>5</mn></mfrac><mo>+</mo><mfrac><mrow><mn>2</mn><mo>&#215;</mo><mn>0</mn><mo>.</mo><mn>4</mn></mrow><mn>20</mn></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>d</mi><mi>K</mi><mo>=</mo><mn>100</mn><mo>+</mo><mn>40</mn><mo>=</mo><mn>140</mn></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>K</mi><mi>E</mi><mo>=</mo><mo>(</mo><mn>1000</mn><mo>&#177;</mo><mn>140</mn><mo>)</mo><mi mathvariant=\"normal\">J</mi></math></p></blockquote>","type":"mcq","source":"JEE Main 2023 (13 Apr Shift 1)","image":null},{"id":44649,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["the same throughout the motion.","minimum when the rope is in the horizontal position.","minimum at the highest position of the circular path.","minimum at the lowest position of the circular path."],"answer":2,"solution":"<p><img src=\"https://.app/pyq/jee_main/9d439266-d480-4545-9f86-defc08a85979-image.png\" style=\"width: 180px; height: 156px;\" /></p><p>As the speed is constant, centripetal force required towards the centre of the circle will be same. At the top, direction of gravitational force and tension acting on the object will be same. Therefore, we can write,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>m</mi><mi>g</mi><mo>+</mo><mi>T</mi><mo>=</mo><mfrac><mrow><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup></mrow><mi>r</mi></mfrac><mo>&#160;</mo><mo>&#8658;</mo><mi>T</mi><mo>=</mo><mfrac><mrow><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup></mrow><mi>r</mi></mfrac><mo>-</mo><mi>m</mi><mi>g</mi></math>.</p><p>&nbsp;Clearly in this case, tension in&nbsp;the string will be minimum.</p><p>&nbsp;</p>","type":"mcq","source":"JEE Main 2022 (24 Jun Shift 2)","image":null},{"id":44558,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["A","B","C","D"],"answer":0,"solution":"The net force acting on the block is the vector sum of the two forces:<br><br>$\\vec{F} = \\vec{F}_1 + \\vec{F}_2 = (2\\hat{i} + 3\\hat{j} + 4\\hat{k}) + (3\\hat{i} - \\hat{j} - 2\\hat{k}) = 5\\hat{i} + 2\\hat{j} + 2\\hat{k}$ N<br><br>The block is moved a distance of $25$ m along the direction of the vector $3\\hat{i} - 4\\hat{j}$. The unit vector along this direction is:<br><br>$\\hat{n} = \\dfrac{3\\hat{i} - 4\\hat{j}}{\\sqrt{3^2 + (-4)^2}} = \\dfrac{3\\hat{i} - 4\\hat{j}}{5}$<br><br>The displacement vector $\\vec{s}$ is the magnitude multiplied by the unit vector:<br><br>$\\vec{s} = 25 \\hat{n} = 25 \\left( \\dfrac{3\\hat{i} - 4\\hat{j}}{5} \\right) = 15\\hat{i} - 20\\hat{j}$ m<br><br>The work done $W$ is the dot product of the net force and the displacement vector:<br><br>$W = \\vec{F} \\cdot \\vec{s} = (5\\hat{i} + 2\\hat{j} + 2\\hat{k}) \\cdot (15\\hat{i} - 20\\hat{j})$<br><br>$W = (5 \\times 15) + (2 \\times -20) + (2 \\times 0)$<br><br>$W = 75 - 40 = 35$ J<br><br>Answer: $35$","type":"mcq","source":"JEE Main 2026 (04 April Shift 1)","image":null},{"id":44562,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["${ }^{t_{P} < t_{Q}}$","${ }^{t_{P}>t_{Q}}$","${ }^{t_{P}=t_{Q}}$","$t_{P}>1.25 t_{Q}$"],"answer":0,"solution":"Horizontal displacement of Q is more than P.<br>$X_Q > X_P$<br>Horizontal component of velocity is same<br>So $t_p = \\dfrac{x_p}{v}$<br>$t_Q = \\dfrac{x_Q}{v}$<br>$t_Q > t_p$","type":"mcq","source":"JEE Main 2026 (23 January Shift 2)","image":null},{"id":44731,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$12.50 \\mathrm{~N}-\\mathrm{m}$","$18.75 \\mathrm{~N}-\\mathrm{m}$","$25.00 \\mathrm{~N}-\\mathrm{m}$","$6.25 \\mathrm{~N}-\\mathrm{m}$"],"answer":1,"solution":"Required work done\n$=\\frac{1}{2} \\mathrm{~K}\\left(\\mathrm{x}_2^2-\\mathrm{x}_1^2\\right)=\\frac{1}{2} \\times 5 \\times 10^3\\left[10^2-5^2\\right] \\times 10^{-4}$\n$=\\frac{1}{2} \\times 5 \\times 75 \\times 10^3 \\times 10^{-4}=18.75$","type":"mcq","source":"JEE Main 2003","image":null},{"id":44625,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>Energy provided will be used to increase kinetic energy of the body. Therefore,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>V</mi><mn>2</mn></msup><mo>=</mo><mi>P</mi><mi>t</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>V</mi><mo>=</mo><msqrt><mfrac><mrow><mn>2</mn><mi>P</mi><mi>t</mi></mrow><mi>m</mi></mfrac></msqrt></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mrow><mi>d</mi><mi>x</mi></mrow><mrow><mi>d</mi><mi>t</mi></mrow></mfrac><mo>=</mo><msqrt><mfrac><mrow><mn>2</mn><mi>P</mi><mi>t</mi></mrow><mi>m</mi></mfrac></msqrt><mspace linebreak=\"newline\"/><mo>&#8658;</mo><msubsup><mo>&#8747;</mo><mn>0</mn><mi>x</mi></msubsup><mi>d</mi><mi>x</mi><mo>=</mo><msqrt><mfrac><mrow><mn>2</mn><mi>P</mi></mrow><mi>m</mi></mfrac></msqrt><msubsup><mo>&#8747;</mo><mn>0</mn><mn>4</mn></msubsup><msup><mi>t</mi><mfrac><mn>1</mn><mn>2</mn></mfrac></msup><mi>d</mi><mi>t</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>x</mi><mo>=</mo><msqrt><mfrac><mrow><mn>2</mn><mi>P</mi></mrow><mi>m</mi></mfrac></msqrt><mfrac><mn>2</mn><mn>3</mn></mfrac><msubsup><mfenced open=\"[\" close=\"]\"><msup><mi>t</mi><mfrac><mn>3</mn><mn>2</mn></mfrac></msup></mfenced><mn>0</mn><mn>4</mn></msubsup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>x</mi><mo>=</mo><mfrac><mrow><mn>16</mn><msqrt><mi>P</mi></msqrt></mrow><mn>3</mn></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>3</mn></mfrac><mo>&#215;</mo><mn>16</mn><msqrt><mi>P</mi></msqrt></math></p><p>Hence, required value of&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#945;</mi><mo>=</mo><mn>4</mn></math>.</p>","type":"mcq","source":"JEE Main 2023 (30 Jan Shift 2)","image":null},{"id":44704,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$\\frac{1}{2} m v^2$","$\\mathrm{mv}^2$","$\\frac{1}{3} \\mathrm{mv}^2$","$\\frac{1}{6} m v^2$"],"answer":3,"solution":"No Solution Available","type":"mcq","source":"JEE Main 2014 (12 Apr Online)","image":null},{"id":44617,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["A","B","C","D"],"answer":0,"solution":"<blockquote><p><img src=\"https://.app/pyq/jee_main/9e619a90-37b0-4e9c-a6c5-03bf66092a39-image.png\" style=\"width: 250px; height: 194px;\" /></p><p>The total kinetic energy of the ball at the bottom of the curve can be calculated as follows:</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>K</mi></mtd><mtd><mo>=</mo></mtd><mtd><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>M</mi><msup><mi>v</mi><mn>2</mn></msup><mo>+</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mo>&#183;</mo><mfrac><mn>2</mn><mn>3</mn></mfrac><mi>M</mi><msup><mi>R</mi><mn>2</mn></msup><msup><mi>&#969;</mi><mn>2</mn></msup></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mo>&#160;</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>M</mi><msup><mi>v</mi><mn>2</mn></msup><mo>+</mo><mfrac><mn>1</mn><mn>3</mn></mfrac><mi>M</mi><msup><mfenced><mrow><mi>R</mi><mi>&#969;</mi></mrow></mfenced><mn>2</mn></msup></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mo>&#160;</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>M</mi><msup><mi>v</mi><mn>2</mn></msup><mo>+</mo><mfrac><mn>1</mn><mn>3</mn></mfrac><mi>M</mi><msup><mi>v</mi><mn>2</mn></msup><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mfenced close=\"]\" open=\"[\"><mrow><mo>&#8757;</mo><mi>v</mi><mo>=</mo><mi>&#969;</mi><mi>R</mi></mrow></mfenced></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mo>&#160;</mo><mfrac><mn>5</mn><mn>6</mn></mfrac><mi>M</mi><msup><mi>v</mi><mn>2</mn></msup><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>1</mn></mfenced></mtd></mtr></mtable></math></p><p>The formula to calculate the potential energy acquired by the ball when it attains the maximum height is given by</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>U</mi><mo>=</mo><mi>M</mi><mi>g</mi><mi>h</mi><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>2</mn></mfenced></math></p><p>Equate equation (1) and (2) and simplify to obtain the required height.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>M</mi><mi>g</mi><mi>h</mi></mtd><mtd><mo>=</mo></mtd><mtd><mfrac><mn>5</mn><mn>6</mn></mfrac><mi>M</mi><msup><mi>v</mi><mn>2</mn></msup></mtd></mtr><mtr><mtd></mtd><mtd><mo>&#8658;</mo></mtd><mtd><mi>h</mi><mo>=</mo><mfrac><mrow><mn>5</mn><msup><mi>v</mi><mn>2</mn></msup></mrow><mrow><mn>6</mn><mi>g</mi></mrow></mfrac><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>3</mn></mfenced></mtd></mtr></mtable></math></p><p>Substitute the values of the known parameters into equation (3) to calculate the required height attained by the ball.<br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"right center left\" columnspacing=\"0px\"><mtr><mtd><mi>h</mi></mtd><mtd><mo>=</mo></mtd><mtd><mfrac><mrow><mn>5</mn><mo>&#215;</mo><msup><mfenced><mrow><mn>3</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></mrow></mfenced><mn>2</mn></msup></mrow><mrow><mn>6</mn><mo>&#215;</mo><mn>10</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>2</mn></mrow></msup></mrow></mfrac></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mo>&#160;</mo><mn>0</mn><mo>.</mo><mn>75</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#215;</mo><mfrac><mrow><mn>100</mn><mo>&#160;</mo><mi>cm</mi></mrow><mrow><mn>1</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi></mrow></mfrac></mtd></mtr><mtr><mtd></mtd><mtd><mo>=</mo></mtd><mtd><mn>75</mn><mo>&#160;</mo><mi>cm</mi></mtd></mtr></mtable></math></p></blockquote>","type":"mcq","source":"JEE Main 2023 (08 Apr Shift 2)","image":null},{"id":44599,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>6</mn><msqrt><mn>5</mn></msqrt><mo> </mo><mi mathvariant=\"normal\">m</mi><mo> </mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>5</mn><msqrt><mn>6</mn></msqrt><mo> </mo><mi mathvariant=\"normal\">m</mi><mo> </mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>5</mn><msqrt><mn>5</mn></msqrt><mo> </mo><mi mathvariant=\"normal\">m</mi><mo> </mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><msqrt><mn>5</mn></msqrt><mo> </mo><mi mathvariant=\"normal\">m</mi><mo> </mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>"],"answer":0,"solution":"<p><img src=\"https://.app/pyq/jee_main/bba87c54-8494-49ca-97ff-5b33d791769a.png\" style=\"width: 163px; height: 170px;\"/></p><p>Given the length of the pendulum is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>ℓ</mi><mo>=</mo><mn>10</mn><mo> </mo><mi mathvariant=\"normal\">m</mi></math>.</p><p>The initial potential energy of the pendulum at the horizontal position is given by</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>U</mi><mo>=</mo><mi>m</mi><mi>g</mi><mi>ℓ</mi><mo> </mo><mo> </mo><mo> </mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>1</mn></mfenced></math></p><p>The final kinetic energy of the pendulum at the lowermost position is given by</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>K</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup><mo> </mo><mo> </mo><mo> </mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>2</mn></mfenced></math></p><p>So, from equations (1) and (2), it follows that</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>9</mn><mn>10</mn></mfrac><mi>m</mi><mi>g</mi><mi>ℓ</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup><mspace linebreak=\"newline\"></mspace><mo>⇒</mo><mfrac><mn>9</mn><mn>10</mn></mfrac><mo>×</mo><mn>10</mn><mo>×</mo><mn>10</mn><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><msup><mi>v</mi><mn>2</mn></msup><mspace linebreak=\"newline\"></mspace><mo>⇒</mo><msup><mi>v</mi><mn>2</mn></msup><mo>=</mo><mn>180</mn><mspace linebreak=\"newline\"></mspace><mo>⇒</mo><mi>v</mi><mo>=</mo><msqrt><mn>180</mn></msqrt><mspace linebreak=\"newline\"></mspace><mo>=</mo><mn>6</mn><msqrt><mn>5</mn></msqrt><mo> </mo><mo> </mo><mi mathvariant=\"normal\">m</mi><mo> </mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math></p>","type":"mcq","source":"JEE Main 2024 (29 Jan Shift 2)","image":null},{"id":44608,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>16</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>.</mo><mn>4</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>4</mn></math>"],"answer":0,"solution":"<blockquote><p>The work done in raising the water is&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>W</mi><mo>=</mo><mi>m</mi><mi>g</mi><mi>h</mi></math>.</p><p>Power is&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>P</mi><mo>=</mo><mfrac><mi>W</mi><mi>t</mi></mfrac></math></p><p>Let the powers of both the motors be&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>P</mi><mn>1</mn></msub><mo>&#160;</mo><mo>&#38;</mo><mo>&#160;</mo><msub><mi>P</mi><mn>2</mn></msub></math>&nbsp;respectively.</p><p>Hence, the ratio of the powers is,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><msub><mi>P</mi><mn>1</mn></msub><msub><mi>P</mi><mn>2</mn></msub></mfrac><mo>=</mo><mfrac><mfrac><mrow><mn>300</mn><mo>&#215;</mo><mi>g</mi><mo>&#215;</mo><mn>100</mn></mrow><mrow><mn>5</mn><mo>&#215;</mo><mn>60</mn></mrow></mfrac><mfrac><mrow><mn>50</mn><mo>&#215;</mo><mi>g</mi><mo>&#215;</mo><mn>100</mn></mrow><mrow><mn>2</mn><mo>&#215;</mo><mn>60</mn></mrow></mfrac></mfrac><mo>=</mo><mfrac><mn>60</mn><mn>25</mn></mfrac><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mfrac><mrow><mn>3</mn><msqrt><mi>x</mi></msqrt></mrow><mrow><msqrt><mi>x</mi></msqrt><mo>+</mo><mn>1</mn></mrow></mfrac><mo>=</mo><mn>2</mn><mo>.</mo><mn>4</mn></math><math xmlns=\"http://www.w3.org/1998/Math/MathML\"></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mn>3</mn><msqrt><mi>x</mi></msqrt><mo>=</mo><mn>2</mn><mo>.</mo><mn>4</mn><msqrt><mi>x</mi></msqrt><mo>+</mo><mn>2</mn><mo>.</mo><mn>4</mn></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>x</mi><mo>=</mo><mn>16</mn></math></p></blockquote>","type":"mcq","source":"JEE Main 2023 (13 Apr Shift 1)","image":null},{"id":44605,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mn>2</mn><mi>g</mi><mi>R</mi></msqrt></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mi>g</mi><mi>R</mi></msqrt></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mn>4</mn><mi>g</mi><mi>R</mi></msqrt></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mfrac><mrow><mi>g</mi><mi>R</mi></mrow><mn>2</mn></mfrac></msqrt></math>"],"answer":1,"solution":"<blockquote><p>Using conservation of mechanical energy,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>U</mi><mi>i</mi></msub><mo>+</mo><msub><mi>K</mi><mi>i</mi></msub><mo>=</mo><msub><mi>U</mi><mi>f</mi></msub><mo>+</mo><msub><mi>K</mi><mi>f</mi></msub></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mo>-</mo><mfrac><mrow><mi>G</mi><mi>M</mi><mi>m</mi></mrow><mrow><mn>2</mn><mi>R</mi></mrow></mfrac><mo>+</mo><mn>0</mn><mo>=</mo><mo>-</mo><mfrac><mrow><mi>G</mi><mi>M</mi><mi>m</mi></mrow><mi>R</mi></mfrac><mo>+</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>v</mi><mn>2</mn></msup><mo>=</mo><mfrac><mrow><mi>G</mi><mi>M</mi><mi>m</mi></mrow><mrow><mn>2</mn><mi>R</mi></mrow></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>v</mi><mo>=</mo><msqrt><mfrac><mi>GM</mi><mi>R</mi></mfrac></msqrt><mo>=</mo><msqrt><mi>g</mi><mi>R</mi></msqrt></math></p></blockquote>","type":"mcq","source":"JEE Main 2023 (15 Apr Shift 1)","image":null},{"id":44696,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mi> </mi><mi>M</mi><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>R</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></math>","<math><mi>M</mi><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>R</mi></mrow><mrow><mn>2</mn></mrow></msup><mi>t</mi></math>","<math><mi>M</mi><mi>n</mi><msup><mrow><mi>R</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></math>","<math><mi>M</mi><mi>n</mi><msup><mrow><mi>R</mi></mrow><mrow><mn>2</mn></mrow></msup><mi>t</mi></math>"],"answer":1,"solution":"<math><msub><mrow><mi>a</mi></mrow><mrow><mi>c</mi></mrow></msub><mo>=</mo><mfrac><mrow><msup><mrow><mi>v</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mi>R</mi></mrow></mfrac><mo>=</mo><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup><mi>R</mi><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></math><br /><br /><math><mi>v</mi><mo>=</mo><mi>n</mi><mi>R</mi><mi>T</mi></math><br /><br /><math><msub><mrow><mi>a</mi></mrow><mrow><mi>t</mi></mrow></msub><mo>=</mo><mfrac><mrow><mi>d</mi><mi>v</mi></mrow><mrow><mi>d</mi><mi>t</mi></mrow></mfrac><mo>=</mo><mi>n</mi><mi>R</mi></math><br /><br />Power <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mi>M</mi><msub><mi>a</mi><mi>t</mi></msub><mi>v</mi></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mi>M</mi><mo>&#160;</mo><mi>n</mi><mi>R</mi><mi>&#160;</mi><mi>n</mi><mi>R</mi><mi>t</mi></math><br /><br /><math><mo>=</mo><mi>M</mi><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>R</mi></mrow><mrow><mn>2</mn></mrow></msup><mi>t</mi></math>","type":"mcq","source":"JEE Main 2016 (10 Apr Online)","image":null},{"id":44706,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math> <mrow> <msup> <mtext>aL</mtext> <mn>2</mn> </msup> <mo>+</mo> <msup> <mtext>bL</mtext> <mn>3</mn> </msup> </mrow> </math>","<math> <mrow> <mfrac> <mrow> <mn>1</mn> </mrow> <mrow> <mn>2</mn> </mrow> </mfrac> <mfenced close=\")\" open=\"(\" separators=\",\"> <mrow> <msup> <mtext>aL</mtext> <mn>2</mn> </msup> <mo>+</mo> <msup> <mtext>bL</mtext> <mn>3</mn> </msup> </mrow> </mfenced> </mrow> </math>","<math> <mrow> <mfrac> <mrow> <msup> <mtext>aL</mtext> <mn>2</mn> </msup> </mrow> <mrow> <mn>2</mn> </mrow> </mfrac> <mo>+</mo> <mfrac> <mrow> <msup> <mtext>bL</mtext> <mn>3</mn> </msup> </mrow> <mrow> <mn>3</mn> </mrow> </mfrac> </mrow> </math>","<math> <mrow> <mfrac> <mrow> <mn>1</mn> </mrow> <mrow> <mn>2</mn> </mrow> </mfrac> <mfenced close=\")\" open=\"(\" separators=\",\"> <mrow> <mfrac> <mrow> <msup> <mtext>aL</mtext> <mn>2</mn> </msup> </mrow> <mrow> <mn>2</mn> </mrow> </mfrac> <mo>+</mo> <mfrac> <mrow> <msup> <mtext>bL</mtext> <mn>3</mn> </msup> </mrow> <mrow> <mn>3</mn> </mrow> </mfrac> </mrow> </mfenced> </mrow> </math>"],"answer":2,"solution":"<math><mrow>  <mtext>W</mtext>  <mo>=</mo>  <mo>&Integral;</mo>  <mtext>F</mtext>  <mtext>d</mtext>  <mtext>x</mtext></mrow></math><br><br><math><mrow>  <mspace width=\"0.5em\" />  <mspace width=\"0.5em\" />  <mspace width=\"0.5em\" />  <mo>=</mo>  <mo>&Integral;</mo>  <mfenced open=\"(\" close=\")\" separators=\",\">    <mrow>      <mtext>ax</mtext>      <mo>+</mo>      <msup>              <mtext>bx</mtext>            <mn>2</mn>      </msup>    </mrow>  </mfenced>  <mtext>dx</mtext></mrow></math><BR><BR><math><mrow>  <mspace width=\"0.5em\" />  <mspace width=\"0.5em\" />  <mspace width=\"0.5em\" />  <mo>=</mo>  <mfrac>    <mrow>      <mtext>a</mtext>    </mrow>    <mrow>      <mn>2</mn>    </mrow>  </mfrac>  <msubsup>        <mrow>          <mfenced open=\"[\" close=\"]\" separators=\",\">            <mrow>              <msup>                      <mtext>x</mtext>                    <mn>2</mn>              </msup>            </mrow>          </mfenced>        </mrow>        <mn>0</mn>        <mtext>L</mtext>  </msubsup>  <mo>+</mo>  <mfrac>    <mrow>      <mtext>b</mtext>    </mrow>    <mrow>      <mn>3</mn>    </mrow>  </mfrac>  <msubsup>        <mrow>          <mfenced open=\"[\" close=\"]\" separators=\",\">            <mrow>              <msup>                      <mtext>x</mtext>                    <mn>3</mn>              </msup>            </mrow>          </mfenced>        </mrow>        <mn>0</mn>        <mtext>L</mtext>  </msubsup></mrow></math><BR><BR><math><mrow>  <mspace width=\"0.5em\" />  <mspace width=\"0.5em\" />  <mspace width=\"0.5em\" />  <mo>=</mo>  <mfrac>    <mrow>      <mtext>a</mtext>      <msup>              <mtext>L</mtext>            <mn>2</mn>      </msup>    </mrow>    <mrow>      <mn>2</mn>    </mrow>  </mfrac>  <mo>+</mo>  <mfrac>    <mrow>      <mtext>b</mtext>      <msup>              <mtext>L</mtext>            <mn>3</mn>      </msup>    </mrow>    <mrow>      <mn>3</mn>    </mrow>  </mfrac></mrow></math>","type":"mcq","source":"JEE Main 2014 (06 Apr)","image":null},{"id":44640,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>4</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>8</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>16</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>"],"answer":3,"solution":"<p>According to the work-energy theorem, work done by all forces will be is equal to the change in kinetic energy.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>W</mi><mi>all</mi></msub><mo>=</mo><mi>&#916;</mi><mi>K</mi></math>&nbsp;&nbsp;</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>m</mi><msup><mi>b</mi><mn>2</mn></msup><mfenced><mrow><msubsup><mi>x</mi><mn>2</mn><mn>5</mn></msubsup><mo>-</mo><msubsup><mi>x</mi><mn>1</mn><mn>5</mn></msubsup></mrow></mfenced></math>&nbsp;&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mo>&#215;</mo><mn>0</mn><mo>.</mo><mn>5</mn><mo>&#215;</mo><mfrac><mn>1</mn><mn>16</mn></mfrac><mo>&#215;</mo><msup><mn>4</mn><mn>5</mn></msup><mo>=</mo><mn>16</mn><mo>&#160;</mo><mi mathvariant=\"normal\">J</mi></math>&nbsp;&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"></math></p>","type":"mcq","source":"JEE Main 2022 (29 Jun Shift 1)","image":null},{"id":44583,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["0","$\\frac{1}{2}$","2","$\\frac{1}{3}$"],"answer":1,"solution":"$\\begin{aligned} & w=0 \\\\ & \\therefore \\quad \\vec{F} \\cdot S=0 \\\\ & (2 \\hat{i}+b \\hat{j}+\\hat{k}) \\cdot(\\hat{i}-2 \\hat{j}-\\hat{k})=0 \\\\ & 2-2 b-1=0 \\\\ & b=\\frac{1}{2}\\end{aligned}$","type":"mcq","source":"JEE Main 2025 (22 Jan Shift 2)","image":null},{"id":44572,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$\\frac{\\mathrm{S}}{2}, \\sqrt{\\frac{3 \\mathrm{gS}}{2}}$","$\\frac{\\mathrm{S}}{2}, \\frac{3 \\mathrm{gS}}{2}$","$\\frac{\\mathrm{S}}{4}, \\frac{3 \\mathrm{gS}}{2}$","$\\frac{\\mathrm{S}}{4}, \\sqrt{\\frac{3 \\mathrm{gS}}{2}}$"],"answer":3,"solution":"$\\begin{aligned}<br/>& \\mathrm{V}^2=0+2 \\mathrm{~g}(\\mathrm{~S}-\\mathrm{x}) \\\\\n& \\mathrm{V}^2=2 \\mathrm{~g}(\\mathrm{~S}-\\mathrm{x})<br/>\\end{aligned}$<br/>At B, Potential energy $=m g x$<br/>$\\begin{aligned}<br/>& \\mathrm{mgx}=3 \\times \\frac{1}{2} \\mathrm{mv}^2 \\\\\n& \\mathrm{gx}=\\frac{3}{2} \\times 2 \\mathrm{~g}(\\mathrm{~S}-\\mathrm{x}) \\\\\n& 4 \\mathrm{x}=\\mathrm{S} \\\\\n& \\mathrm{x}=\\frac{\\mathrm{S}}{4}<br/>\\end{aligned}$<br/>$\\Rightarrow \\mathrm{V}=\\sqrt{2 \\mathrm{~g} \\times \\frac{3 \\mathrm{~S}}{4}}=\\sqrt{\\frac{3 \\mathrm{gS}}{2}}$","type":"mcq","source":"JEE Main 2025 (3 Apr Shift 1)","image":null},{"id":44635,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn><mo>.</mo><mn>25</mn><mo>&#160;</mo><mi mathvariant=\"normal\">W</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">W</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>6</mn><mo>.</mo><mn>25</mn><mo>&#160;</mo><mi mathvariant=\"normal\">W</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>12</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">W</mi></math>"],"answer":3,"solution":"<blockquote><p>When the sand is dropped on the conveyor belt its velocity will become equal to that of the conveyor. Therefore,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>v</mi><mo>=</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math>.</p><p>The force required to keep the conveyor belt moving will be equal to the gain in the momentum by the sand per second.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>F</mi><mo>=</mo><mfrac><mrow><mo>d</mo><mi>m</mi></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac><mi>v</mi><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mi>F</mi><mo>=</mo><mn>0</mn><mo>.</mo><mn>5</mn><mo>&#215;</mo><mn>5</mn><mo>=</mo><mn>2</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math></p><p>Now the power required to keep the conveyor belt moving will be,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>P</mi><mo>=</mo><mi>F</mi><mi>v</mi><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mi>P</mi><mo>=</mo><mn>2</mn><mo>.</mo><mn>5</mn><mo>&#215;</mo><mn>5</mn><mo>=</mo><mn>12</mn><mo>.</mo><mn>5</mn><mo>&#160;</mo><mi mathvariant=\"normal\">W</mi><mo>.</mo></math></p></blockquote>","type":"mcq","source":"JEE Main 2022 (27 Jul Shift 1)","image":null},{"id":44733,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$16 \\mathrm{~J}$\noption 1 goes here","$8 \\mathrm{~J}$","$32 \\mathrm{~J}$","$24 \\mathrm{~J}$"],"answer":1,"solution":"$\\mathrm{W}=\\int_{x_1}^{x_2} F d x=\\int_{x_1}^{x_2} K x d x=K\\left[\\frac{x^2}{2}\\right]_{x_1}^{x_2}=\\frac{K}{2}\\left[x_2^2-x_1^2\\right]=\\frac{800}{2}\\left[(0.15)^2-(0.05)^2\\right]=8 \\mathrm{~J}$","type":"mcq","source":"JEE Main 2002","image":null},{"id":44585,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["A","B","C","D"],"answer":0,"solution":"$\\begin{aligned} & W=\\int_{x_1}^{x_2} F d x \\\\ & W=\\int_2^4\\left(3 x^2+2 x-5\\right) d x \\\\ & W=\\left[x^3+x^2-5 x\\right]_2^4 \\\\ & W=[60-2] J=58 J\\end{aligned}$","type":"mcq","source":"JEE Main 2024 (09 Apr Shift 2)","image":null},{"id":44554,"subject":"Physics","chapter":"Work Power Energy","question":"","options":["$0$","$250$","$1250$","$1000$"],"answer":2,"solution":"Given mass $m = 1$ kg and velocity $v = 2x^2$.<br><br>According to the work-energy theorem, the work done by the net force is equal to the change in kinetic energy of the body.<br><br>$W = \\Delta K = K_f - K_i$<br><br>At $x = 0$ m, initial velocity $v_i = 2(0)^2 = 0$ m/s.<br><br>At $x = 5$ m, final velocity $v_f = 2(5)^2 = 50$ m/s.<br><br>Initial kinetic energy $K_i = \\dfrac{1}{2} m v_i^2 = 0$ J.<br><br>Final kinetic energy $K_f = \\dfrac{1}{2} m v_f^2 = \\dfrac{1}{2} \\times 1 \\times (50)^2 = 1250$ J.<br><br>Work done $W = 1250 - 0 = 1250$ J.<br><br>Answer: $1250$","type":"mcq","source":"JEE Main 2026 (06 April Shift 2)","image":null}]