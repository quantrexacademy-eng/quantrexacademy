l\">E</mi><mn>3</mn><mn>0</mn></msubsup><mo>=</mo></math>?</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi>&#916;G</mi><mn>3</mn><mn>0</mn></msubsup><mo>=</mo><mo>-</mo><mn>2</mn><mo>&#160;</mo><mi mathvariant=\"normal\">F</mi><mfenced close=\"]\" open=\"[\"><msubsup><mi mathvariant=\"normal\">E</mi><mn>3</mn><mn>0</mn></msubsup></mfenced></math></p><p>Target Eq.<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo></math>Eq. ii&nbsp;- Eq. i</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>-</mo><mn>2</mn><mi mathvariant=\"normal\">F</mi><mfenced><msubsup><mi mathvariant=\"normal\">E</mi><mn>3</mn><mn>0</mn></msubsup></mfenced><mo>=</mo><mo>-</mo><mn>4</mn><mi mathvariant=\"normal\">F</mi><mfenced><mrow><mn>0</mn><mo>.</mo><mn>010</mn></mrow></mfenced><mo>-</mo><mfenced><mrow><mo>-</mo><mn>2</mn><mi mathvariant=\"normal\">F</mi><mfenced><mrow><mo>-</mo><mn>0</mn><mo>.</mo><mn>14</mn></mrow></mfenced></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi mathvariant=\"normal\">E</mi><mn>3</mn><mn>0</mn></msubsup><mo>=</mo><mfrac><mrow><mn>4</mn><mo>&#215;</mo><mn>0</mn><mo>.</mo><mn>010</mn><mo>+</mo><mn>2</mn><mo>&#215;</mo><mn>0</mn><mo>.</mo><mn>14</mn></mrow><mn>2</mn></mfrac><mo>=</mo><mn>0</mn><mo>.</mo><mn>16</mn><mo>&#160;</mo><mi mathvariant=\"normal\">V</mi><mo>=</mo><mn>16</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>2</mn></mrow></msup><mo>&#160;</mo><mi mathvariant=\"normal\">V</mi></math></p>","type":"mcq","source":"JEE Main 2022 (28 Jun Shift 2)","image":null},{"id":29412,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">E</mi><mo>=</mo><mi mathvariant=\"normal\">E</mi><mo>&#176;</mo><mo>-</mo><mfrac><mrow><mn>0</mn><mo>.</mo><mn>059</mn></mrow><mn>2</mn></mfrac><mi>log</mi><mfrac><mfenced close=\"]\" open=\"[\"><msup><mi>Cu</mi><mrow><mo>+</mo><mn>2</mn></mrow></msup></mfenced><msup><mfenced close=\"]\" open=\"[\"><msup><mi>Ag</mi><mo>+</mo></msup></mfenced><mn>2</mn></msup></mfrac></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mn>2</mn><mo>.</mo><mn>97</mn><mo>-</mo><mfrac><mrow><mn>0</mn><mo>.</mo><mn>059</mn></mrow><mn>2</mn></mfrac><mi>log</mi><mfrac><mrow><mn>0</mn><mo>.</mo><mn>25</mn></mrow><msup><mfenced><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup></mfenced><mn>2</mn></msup></mfrac><mo>=</mo><mn>2</mn><mo>.</mo><mn>81</mn><mo>&#160;</mo><mi mathvariant=\"normal\">V</mi></math>","type":"mcq","source":"JEE Main 2021 (22 Jul Shift 1)","image":null},{"id":29445,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["<math><mn>0.125</mn></math>","<math><mn>0.75</mn></math>","<math><mn>0.25</mn></math>","<math><mn>0.50</mn></math>"],"answer":0,"solution":"<p>Kohlrausch&#39;s law states that&nbsp;the equivalent conductivity of an electrolyte at infinite dilution is equal to the sum of the conductances of the anions and cations.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi mathvariant=\"normal\">&#955;</mi><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">o</mi></msubsup><mfenced separators=\"|\"><mi>HA</mi></mfenced><mo>=</mo><msubsup><mi mathvariant=\"normal\">&#955;</mi><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">o</mi></msubsup><mfenced separators=\"|\"><mi>HCl</mi></mfenced><mo>+</mo><msubsup><mi mathvariant=\"normal\">&#955;</mi><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">o</mi></msubsup><mfenced separators=\"|\"><mi>NaA</mi></mfenced><mo>-</mo><msup><mi mathvariant=\"normal\">&#955;</mi><mi mathvariant=\"normal\">o</mi></msup><mfenced separators=\"|\"><mi>NaCl</mi></mfenced></math><br /><br /><math><mo>=</mo><mn>425.9</mn><mo>+</mo><mn>100.5</mn><mo>-</mo><mn>126.4</mn></math><br /><br /><math><mo>=</mo><mn>400</mn></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi mathvariant=\"normal\">&#955;</mi><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">o</mi></msubsup><mo>=</mo><mfrac><mrow><mi mathvariant=\"normal\">K</mi><mo>&#215;</mo><mn>1000</mn></mrow><mi mathvariant=\"normal\">M</mi></mfrac><mo>=</mo><mfrac><mrow><mn>5</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>5</mn></mrow></msup><mo>&#215;</mo><msup><mn>10</mn><mn>3</mn></msup></mrow><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup></mfrac><mo>=</mo><mn>50</mn></math><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">&#945;</mi><mo>=</mo><mfrac><mn>50</mn><mn>400</mn></mfrac><mo>=</mo><mn>0</mn><mo>.125</mo></math></p>","type":"mcq","source":"JEE Main 2019 (12 Jan Shift 2)","image":null},{"id":29284,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$\\dfrac{2}{3.9}$","$\\dfrac{4}{5.9}$","$\\dfrac{2.9}{2}$","$\\dfrac{5.9}{4}$"],"answer":1,"solution":"The cell reaction is $Zn(s) + 2Ag^+(aq) \\rightarrow Zn^{2+}(aq) + 2Ag(s)$<br><br>The standard cell potential is given by:<br>$E^\\circ_{cell} = E^\\circ_{cathode} - E^\\circ_{anode} = 0.80 - (-0.76) = 1.56\\text{ V}$<br><br>Using the Nernst equation:<br>$E_{cell} = E^\\circ_{cell} - \\dfrac{0.059}{n} \\log \\dfrac{[Zn^{2+}]}{[Ag^+]^2}$<br><br>Substituting the given values ($n = 2$, $[Zn^{2+}] = 1\\text{ M}$, $E_{cell} = 1.60\\text{ V}$):<br>$1.60 = 1.56 - \\dfrac{0.059}{2} \\log \\dfrac{1}{x^2}$<br><br>$0.04 = - \\dfrac{0.059}{2} (-2 \\log x)$<br><br>$0.04 = 0.059 \\log x$<br><br>$\\log x = \\dfrac{0.04}{0.059} = \\dfrac{4}{5.9}$<br><br>Answer: $\\dfrac{4}{5.9}$","type":"mcq","source":"JEE Main 2026 (05 April Shift 2)","image":null},{"id":29353,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>Given,<br/>pH =<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>3</mn></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>⇒</mo><mo>-</mo><mo> </mo><mi>log</mi><mo> </mo><mo>[</mo><mo> </mo><msup><mi mathvariant=\"normal\">H</mi><mo>+</mo></msup><mo>]</mo><mo> </mo><mo>=</mo><mo> </mo><mn>3</mn><mspace linebreak=\"newline\"></mspace><mo>[</mo><mo> </mo><msup><mi mathvariant=\"normal\">H</mi><mo>+</mo></msup><mo>]</mo><mo> </mo><mo>=</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup><mspace linebreak=\"newline\"></mspace></math></p><p>The half cell reaction is</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><msubsup><mi mathvariant=\"normal\">H</mi><mrow><mo>(</mo><mi>aq</mi><mo>.</mo><mo>)</mo></mrow><mo>+</mo></msubsup><mo>+</mo><mn>2</mn><msup><mi mathvariant=\"normal\">e</mi><mo>-</mo></msup><mo>→</mo><msub><msub><mi mathvariant=\"normal\">H</mi><mn>2</mn></msub><mfenced><mi mathvariant=\"normal\">g</mi></mfenced></msub></math></p><p>We know,</p><p>the Nernst equation is<br/><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi mathvariant=\"normal\">E</mi><mi>red</mi></msub><mo>=</mo><msub><msup><mi mathvariant=\"normal\">E</mi><mn>0</mn></msup><mi>red</mi></msub><mo>+</mo><mn>0</mn><mo>.</mo><mn>059</mn><mo> </mo><mi>log</mi><mo> </mo><mo>[</mo><msup><mi mathvariant=\"normal\">H</mi><mo>+</mo></msup><mo>]</mo><mspace linebreak=\"newline\"></mspace><mo>=</mo><mn>0</mn><mo>+</mo><mn>0</mn><mo>.</mo><mn>059</mn><mo> </mo><mo> </mo><mi>log</mi><mo> </mo><msup><mn>10</mn><mrow><mo>−</mo><mn>3</mn></mrow></msup><mspace linebreak=\"newline\"></mspace><mo>=</mo><mo>+</mo><mo> </mo><mn>0</mn><mo>.</mo><mn>059</mn><mo> </mo><mo>×</mo><mo>(</mo><mo>−</mo><mn>3</mn><mo>)</mo><mo> </mo><mspace linebreak=\"newline\"></mspace><mo>=</mo><mo>−</mo><mo> </mo><mn>0</mn><mo>.</mo><mn>177</mn><mo> </mo><mo> </mo><mo> </mo><mi mathvariant=\"normal\">V</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mo> </mo><mo>-</mo><mn>17</mn><mo>.</mo><mn>7</mn><mo>×</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>2</mn></mrow></msup><mi mathvariant=\"normal\">V</mi></math>.</p>","type":"mcq","source":"JEE Main 2024 (27 Jan Shift 2)","image":null},{"id":29315,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A small decrease in molar conductivity is observed at infinite dilution.","Molar conductivity decreases sharply with increase in concentration.","A small increase in molar conductivity is observed at infinite dilution.","Molar conductivity increases sharply with increase in concentration."],"answer":1,"solution":"For weak electrolyte, variation of $\\wedge_m$ with $\\sqrt{\\mathrm{c}}$ is\n<img src=\"https://.app/pyq/jee_main/bLT1WG_QjBKocV15e3ObMSJlJv1mmm9glSLfaa5urVE.original.fullsize.png\"><br>","type":"mcq","source":"JEE Main 2025 (29 Jan Shift 1)","image":null},{"id":29511,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$\\mathrm{Sm} \\mathrm{~mol} ^{-1}$","$\\mathrm{Sm}^2 \\mathrm{~mol}^{-1}$","$\\mathrm{S}^{-2} \\mathrm{~m}^2 \\mathrm{~mol}$","$\\mathrm{S}^2 \\mathrm{~m}^2 \\mathrm{~mol}^{-2}$"],"answer":1,"solution":"No Solution Available","type":"mcq","source":"JEE Main 2002","image":null},{"id":29292,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"For weak acids with $\\lambda^{\\infty}Q^- = \\lambda^{\\infty}Z^-$, the molar conductivity is $\\lambda_m = \\alpha \\lambda^{\\infty}$.<br>From $\\lambda_m^Q = \\frac{1}{30}\\lambda_m^Z$, we get $\\alpha_Q = \\frac{\\alpha_Z}{30}$.<br>Using $K_a = \\alpha^2 C$ for weak acids: $K_a(HQ) = \\alpha_Q^2 \\times 0.18 = \\frac{\\alpha_Z^2 \\times 0.18}{900}$ and $K_a(HZ) = \\alpha_Z^2 \\times 0.02$.<br>Therefore $\\frac{K_a(HZ)}{K_a(HQ)} = \\frac{0.02 \\times 900}{0.18} = 100$.<br>Thus $pK_a(HQ) - pK_a(HZ) = \\log(100) = 2$.","type":"mcq","source":"JEE Main 2026 (24 January Shift 2)","image":null},{"id":29483,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$\\mathrm{Ag}, \\mathrm{Hg}, \\mathrm{Cu}, \\mathrm{Mg}$","$\\mathrm{Cu}, \\mathrm{Hg}$, Ag only","Ag, Hg, Cu only","$\\mathrm{Mg}, \\mathrm{Cu}, \\mathrm{Hg}, \\mathrm{Ag}$"],"answer":2,"solution":"More the reduction potential, more is the deposition of metals at cathode. Cation having $\\mathrm{E}^0$ value less than $-0.83 \\mathrm{~V}$ (reduction potential of $\\mathrm{H}_2 \\mathrm{O}$ ) will not deposit from aqueous solution. Hence correct order of A deposition of the metal at the cathode is","type":"mcq","source":"JEE Main 2012 (19 May Online)","image":null},{"id":29478,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$0.3892 \\mathrm{~g}$","$0.2938 \\mathrm{~g}$","$0.2398 \\mathrm{~g}$","$0.3928 \\mathrm{~g}$"],"answer":1,"solution":"$\\mathrm{W}=\\mathrm{Zit}$\nwhere $\\mathrm{Z}$ = Electrochemical equivalent\nEq. wt. of copper $=\\frac{63}{2}=31.5$\n$\\begin{aligned}\n& \\mathrm{Z}=\\frac{31.5}{96500} \\\\\n& \\mathrm{~W}=\\mathrm{Zit}=\\frac{31.5}{96500} \\times 1.5 \\times 10 \\times 60=0.2938 \\mathrm{~g}\n\\end{aligned}$","type":"mcq","source":"JEE Main 2013 (25 Apr Online)","image":null},{"id":29357,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>One equivalent of substance deposited for&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>96500</mn><mi mathvariant=\"normal\">C</mi></math>(one Faraday).</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">i</mi><mo>&#215;</mo><mi mathvariant=\"normal\">t</mi></math>&nbsp;Columbus of charge can be utilised to get&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">w</mi><mo>&#160;</mo><mi mathvariant=\"normal\">g</mi></math>&nbsp;of substance.</p><p>Millimoles of&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Ni</mi></math>&nbsp;coated</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mrow><mo>(</mo><mn>2</mn><mi mathvariant=\"normal\">x</mi><mo>)</mo><mn>100</mn></mrow><mrow><mn>96500</mn><mo>&#215;</mo><mn>2</mn></mrow></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mrow><mn>10</mn><mi mathvariant=\"normal\">x</mi></mrow><mn>965</mn></mfrac></math></p><p>Mass of&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Ni</mi><mo>=</mo><mfenced><mfrac><mi mathvariant=\"normal\">x</mi><mn>965</mn></mfrac></mfenced><mn>600</mn></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mrow><mn>600</mn><mi mathvariant=\"normal\">x</mi></mrow><mn>965</mn></mfrac><mi>mg</mi></math></p><p>Volume<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mrow><mn>60</mn><mi mathvariant=\"normal\">x</mi></mrow><mn>965</mn></mfrac><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>3</mn></mrow></msup><mo>&#160;</mo><msup><mi>cm</mi><mn>3</mn></msup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mn>100</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>4</mn></mrow></msup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi mathvariant=\"normal\">x</mi><mo>=</mo><mn>0</mn><mo>.</mo><mn>1608</mn><mo>&#215;</mo><msup><mn>10</mn><mn>3</mn></msup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8776;</mo><mn>161</mn></math></p>","type":"mcq","source":"JEE Main 2023 (13 Apr Shift 1)","image":null},{"id":29485,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$X=N i, Y=F e$","$X=N i, Y=Z n$","$X=F e, Y=Z n$","$X=Z n, Y=N i$"],"answer":3,"solution":"$\\begin{aligned}\n& \\mathrm{Zn}+\\mathrm{Fe}^{+2} \\rightarrow \\mathrm{Zn}^{+2}+\\mathrm{Fe} \\\\\n& \\mathrm{Fe}+\\mathrm{Ni}^{+2} \\rightarrow \\mathrm{Fe}^{2+}+\\mathrm{Ni} \\\\\n& \\mathrm{Zn}+\\mathrm{Ni}^{2+} \\rightarrow \\mathrm{Zn}^{+2}+\\mathrm{Ni}\n\\end{aligned}$\nAll these are spontaneous","type":"mcq","source":"JEE Main 2012 (Offline)","image":null},{"id":29343,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>For the reaction at equilibrium,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><msubsup><mi>MnO</mi><mn>4</mn><mo>-</mo></msubsup><mo>+</mo><mn>6</mn><msup><mi mathvariant=\"normal\">H</mi><mo>+</mo></msup><mo>+</mo><mn>5</mn><msub><mi mathvariant=\"normal\">H</mi><mn>2</mn></msub><msub><mi mathvariant=\"normal\">C</mi><mn>2</mn></msub><msub><mi mathvariant=\"normal\">O</mi><mn>4</mn></msub><mo>⇌</mo><mn>2</mn><msup><mi>Mn</mi><mrow><mn>2</mn><mo>+</mo></mrow></msup><mo>+</mo><mn>8</mn><msub><mi mathvariant=\"normal\">H</mi><mn>2</mn></msub><mi mathvariant=\"normal\">O</mi><mo>+</mo><mn>10</mn><msub><mi>CO</mi><mn>2</mn></msub><mo>.</mo></math></p><p>Given : <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi mathvariant=\"normal\">E</mi><mrow><msubsup><mi>MnO</mi><mn>4</mn><mo>-</mo></msubsup><mo>/</mo><mo> </mo><msup><mi>Mn</mi><mrow><mn>2</mn><mo>+</mo></mrow></msup></mrow><mn>0</mn></msubsup><mo>=</mo><mn>1</mn><mo>.</mo><mn>51</mn><mo> </mo><mi mathvariant=\"normal\">V</mi><mo> </mo><mi>and</mi><mo> </mo><msub><msup><mi mathvariant=\"normal\">E</mi><mn>0</mn></msup><mrow><msub><mi mathvariant=\"normal\">H</mi><mn>2</mn></msub><msub><mi mathvariant=\"normal\">C</mi><mn>2</mn></msub><msubsup><mi mathvariant=\"normal\">O</mi><mn>4</mn><mrow></mrow></msubsup><mo>/</mo><msub><mi>CO</mi><mn>2</mn></msub></mrow></msub><mo>=</mo><mn>0</mn><mo>.</mo><mn>49</mn><mo> </mo><mi mathvariant=\"normal\">V</mi><mo>.</mo></math></p><p>So,  <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi mathvariant=\"normal\">E</mi><mi>cell</mi><mn>0</mn></msubsup><mo> </mo><mo>=</mo><mn>1</mn><mo>.</mo><mn>51</mn><mo> </mo><mo>+</mo><mo> </mo><mn>0</mn><mo>.</mo><mn>49</mn><mo>=</mo><mn>2</mn><mo> </mo><mi mathvariant=\"normal\">V</mi><mo>.</mo></math></p><p>Number of electrons involved in reaction can be calculated as follows:</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mi>Mn</mi><mrow><mo>+</mo><mn>7</mn><mo> </mo></mrow></msup><mo> </mo><mi>changes</mi><mo> </mo><msup><mi>Mn</mi><mrow><mn>2</mn><mo>+</mo></mrow></msup></math> so, each  <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>Mn</mi></math> gain five electrons.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">n</mi><mo> </mo><mo>=</mo><mo> </mo><mn>10</mn></math></p><p>Now, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msubsup><mi mathvariant=\"normal\">E</mi><mi>cell</mi><mn>0</mn></msubsup><mo> </mo><mo>=</mo><mfrac><mrow><mn>0</mn><mo>.</mo><mn>0591</mn></mrow><mi mathvariant=\"normal\">n</mi></mfrac><mi>log</mi><mo> </mo><mi mathvariant=\"normal\">K</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>log</mi><mo> </mo><mi mathvariant=\"normal\">K</mi><mo> </mo><mo>=</mo><mfrac><mrow><mn>10</mn><mo>×</mo><mn>2</mn></mrow><mrow><mn>0</mn><mo>.</mo><mn>0591</mn></mrow></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>log</mi><mo> </mo><mi mathvariant=\"normal\">K</mi><mo> </mo><mo>=</mo><mn>338</mn><mo>.</mo><mn>4</mn></math></p>","type":"mcq","source":"JEE Main 2024 (01 Feb Shift 2)","image":null},{"id":29424,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>Number of faradays =&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mi mathvariant=\"normal\">I</mi><mo>&#215;</mo><mi mathvariant=\"normal\">t</mi></mrow><mn>96500</mn></mfrac></math></p><p>&nbsp;=<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mn>2</mn><mo>&#215;</mo><mi mathvariant=\"normal\">t</mi><mo>&#215;</mo><mn>60</mn><mo>&#215;</mo><mn>60</mn></mrow><mn>96500</mn></mfrac><mi mathvariant=\"normal\">F</mi></math></p><p>Mass of&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>KClO</mi><mn>3</mn></math>&nbsp;produce =&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>10</mn><mo>&#160;</mo><mi>Gm</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#160;&#160;</mo><mo>{</mo><mn>2</mn><mo>&#215;</mo><mi>t</mi><mo>&#215;</mo><mn>60</mn><mo>&#215;</mo><mn>60</mn><mo>/</mo><mn>96500</mn><mo>}</mo><mo>&#215;</mo><mn>0</mn><mo>.</mo><mn>60</mn><mo>&#215;</mo><mn>122</mn><mo>&#215;</mo><mo>(</mo><mn>1</mn><mo>/</mo><mn>6</mn><mo>)</mo><mo>=</mo><mn>10</mn></math><br />So <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">t</mi><mo>=</mo><mn>10</mn><mo>.</mo><mn>98</mn></math> hours</p>","type":"mcq","source":"JEE Main 2020 (06 Sep Shift 1)","image":null},{"id":29447,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$0.04736 \\mathrm{mV}$","$0.4736 \\mathrm{mV}$","$0.4736 \\mathrm{~V}$","$0.04736 \\mathrm{~V}$"],"answer":2,"solution":"$E_{\\text {cell }}^{0}=\\frac{2.303 \\mathrm{RT}}{\\mathrm{nF}} \\log \\mathrm{K}_{\\mathrm{C}}$ or $\\mathrm{E}_{\\text {cell }}^{0}=\\frac{0.059 \\mathrm{~V}}{\\mathrm{n}} \\log \\mathrm{K}_{\\mathrm{C}}$\r\n\r\n$$\r\n\r\n=\\frac{0.059 \\mathrm{~V}}{2} \\log 10^{16}=0.4736 \\mathrm{~V}\r\n\r\n$$","type":"mcq","source":"JEE Main 2019 (11 Jan Shift 2)","image":null},{"id":29509,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["$10.8 \\mathrm{~g}$","$21.6 \\mathrm{~g}$","$108 \\mathrm{~g}$","$1.08 \\mathrm{~g}$"],"answer":0,"solution":"No. of moles of silver $=\\frac{9650}{96500}=\\frac{1}{10}$ moles\n$\\therefore$ Mass of silver deposited $=\\frac{1}{10} \\times 108=10.8 \\mathrm{~g}$","type":"mcq","source":"JEE Main 2003","image":null},{"id":29298,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["A","B","C","D"],"answer":0,"solution":"The electrochemical cell has cathode:<br>$Bi_2O_3 + 3H_2O + 6e^- \\rightarrow 2Bi + 6OH^-$ with $E° = -0.44$ V<br>and anode:<br>$Sn(OH)_6^{2-} - 2e^- \\rightarrow HSnO_2^- + H_2O + OH^-$ with $E° = -0.90$ V.<br>The standard cell EMF is $E°_{cell} = -0.44 - (-0.90) = 0.46$ V.<br>Using the Nernst equation with $Q = 10^6$ and $n = 6$ electrons transferred:<br>$E_{cell} = 0.46 - \\frac{0.059}{6} \\log(10^6) = 0.46 - \\frac{0.059 \\times 6}{6} = 0.46 - 0.059 = 0.401$ V.<br>Expressing as $x \\times 10^{-1}$ V:<br>$0.401 = 4.01 \\times 10^{-1}$ V, so $x = 4$ (nearest integer).","type":"mcq","source":"JEE Main 2026 (22 January Shift 1)","image":null},{"id":29314,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["(A)-(III), (B)-(II), (C)-(IV), (D)-(I)","(A)-(II), (B)-(III), (C)-(IV), (D)-(I)","(A)-(III), (B)-(I), (C)-(IV), (D)-(II)","(A)-(IV), (B)-(III), (C)-(II), (D)-(I)"],"answer":2,"solution":"In transistor, anode is Zn and cathode is carbon.\nIn hearing, aids mercury battery are used.\nIn invertors, lead storage battery is used.\nIn apollo space ship, hydrogen fuel cell was used.","type":"mcq","source":"JEE Main 2025 (29 Jan Shift 2)","image":null},{"id":29451,"subject":"Chemistry","chapter":"Electrochemistry","question":"","options":["<math><msup><mrow><mi>e</mi></mrow><mrow><mo>-</mo><mn>160</mn></mrow></msup></math>","<math><msup><mrow><mi>e</mi></mrow><mrow><mo>-</mo><mn>80</mn></mrow></msup></math>","<math><msup><mrow><mi>e</mi></mrow><mrow><mn>160</mn></mrow></msup></math>","<math><msup><mrow><mi>e</mi></mrow><mrow><mn>320</mn></mrow></msup></math>"],"answer":2,"solution":"<blockquote><p><math><mo>&#8710;</mo><mi>G</mi><mo>=</mo><mo>&#8710;</mo><msup><mrow><mi>G</mi></mrow><mrow><mi>o</mi></mrow></msup><mo>+</mo><mi>R</mi><mi>T</mi><mi>l</mi><mi>n</mi><mi>Q</mi></math><br />At equilibrium <math><mo>&#8710;</mo><mi>G</mi><mo>=</mo><mn>0</mn><mo>,</mo><mi>&#160;</mi><mi>Q</mi><mo>=</mo><mi>k</mi></math><br /><math><mn>0</mn><mo>=</mo><mo>&#8710;</mo><msup><mrow><mi>G</mi></mrow><mrow><mi>o</mi></mrow></msup><mo>+</mo><mi>R</mi><mi>T</mi><mi>&#160;</mi><mi>l</mi><mi>n</mi><mi>K</mi></math><br /><math><mo>&#8710;</mo><msup><mrow><mi>G</mi></mrow><mrow><mi>o</mi></mrow></msup><mo>=</mo><mo>-</mo><mi>R</mi><mi>T</mi><mi>&#160;</mi><mi>l</mi><mi>n</mi><mi>K</mi><mi>&#160;</mi><mfenced separators=\"|\"><mrow><mo>&#8756;</mo><mo>&#8710;</mo><msup><mrow><mi>G</mi></mrow><mrow><mi>o</mi></mrow></msup><mo>=</mo><mo>-</mo><mi>n</mi><mi>F</mi><msup><mrow><mi>E</mi></mrow><mrow><mi>o</mi></mrow></msup></mrow></mfenced></math><br />So <math><mo>-</mo><mi>n</mi><mi>F</mi><msup><mrow><mi>E</mi></mrow><mrow><mi>o</mi></mrow></msup><mo>=</mo><mo>-</mo><mi>R</mi><mi>T</mi><mi>&#160;</mi><mi>l</mi><mi>n</mi><mi>k</mi></math><br /><math><mi>&#8242;</mi><mi>n</mi><mi>&#8242;</mi></math> factor for the above cell <math><mo>=</mo><mn>2</mn></math><br />So <math><mo>-</mo><mn>2</mn><mo>&#215;</mo><mn>96000</mn><mo>&#215;</mo><mn>2</mn><mo>=</mo><mo>-</mo><mn>8</mn><mo>&#215;</mo><mn>300</mn><mi>&#160;</mi><mi>l</mi><mi>n</mi><mi>k</mi></math><br /><math><mi>l</mi><mi>n</mi><mi>k</mi><mo>=</mo><mn>160</mn></math><br /><math><mi>k</mi><mo>=</mo><msup><mrow><mi>e</mi></mrow><mrow><mn>160</mn></mrow></msup></math></p></blockquote>","type":"mcq","source":"JEE Main 2019 (09 Jan Shift 2)","image":null}]