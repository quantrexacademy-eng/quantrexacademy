6bc-00731d4140e0-image.png\" style=\"width: 100px; height: 100px;\" /></p><p>&nbsp;</p>","<img src=\"https://.app/pyq/jee_main/fb74d710-e68d-4135-8887-392379000a50-image.png\" style=\"width: 100px; height: 102px;\" />","<img src=\"https://.app/pyq/jee_main/86a35c2f-cef2-4a12-a67f-e063158c8ac6-image.png\" style=\"width: 95px; height: 115px;\" />","<img src=\"https://.app/pyq/jee_main/e3b34086-a4ef-4056-9865-b4da7905883a-image.png\" style=\"width: 100px; height: 107px;\" />"],"answer":0,"solution":"<p><img src=\"https://.app/pyq/jee_main/89cdb76a-52b0-4f41-a6bc-00731d4140e0-image.png\" style=\"width: 100px; height: 100px;\" /></p><p>is&nbsp;the most stable and because of aromatic character as it satisfies H&uuml;ckel&#39;s rule(It has 2 pi electrons, it is cyclic, planar and conjugated)</p><p><img src=\"https://.app/pyq/jee_main/fb74d710-e68d-4135-8887-392379000a50-image.png\" style=\"width: 100px; height: 102px;\" /> and&nbsp;<img src=\"https://.app/pyq/jee_main/86a35c2f-cef2-4a12-a67f-e063158c8ac6-image.png\" style=\"width: 95px; height: 115px;\" />&nbsp;are highly unstable due to anti-aromatic behaviuor(Both the species have 4 pi electrons)</p><p>Hence, option A is the correct answer.</p>","type":"mcq","source":"JEE Main 2022 (27 Jun Shift 2)","image":null},{"id":29893,"subject":"Chemistry","chapter":"General Organic Chemistry","question":"","options":["Both statement I and statement II are false","Statement I&nbsp;is incorrect but statement II is true","Statement I is correct but statement II is false","Both Statement I and statement II are true."],"answer":2,"solution":"Statement I : It is correct statement<br />Statement II : <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>CH</mi><mn>3</mn></msub><mo>-</mo><msub><mi>CH</mi><mn>2</mn></msub></math> involve <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi mathvariant=\"normal\">C</mi><msup><mi>sp</mi><mn>3</mn></msup></msub><mo>-</mo><msub><mi mathvariant=\"normal\">H</mi><mrow><mn>1</mn><