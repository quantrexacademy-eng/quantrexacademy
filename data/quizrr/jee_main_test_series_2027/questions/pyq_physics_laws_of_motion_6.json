[{"id":41347,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["Speed which is <math><mfrac><mrow><mn>3</mn></mrow><mrow><mn>4</mn></mrow></mfrac><mi mathvariant=\"normal\">t</mi><mi mathvariant=\"normal\">h</mi></math> of that of the roller when the weight is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>4</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi></math> above the ground","Constant speed","Decreasing speed","Increasing speed"],"answer":2,"solution":"<p><img src=\"https://.app/pyq/jee_main/19531626-a5c9-434c-a939-63eefa1a20fd-d40.png\" style=\"width: 250px; height: 233px;\" /><br /><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>v</mi><mi>A</mi></msub><mo>=</mo><mfrac><mrow><mo>d</mo><mi>x</mi></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac><mo>=</mo><mfrac><mrow><mo>d</mo><mfenced close=\"]\" open=\"[\"><mrow><mn>2</mn><mi>l</mi><mi>cos</mi><mfenced><mi>&#952;</mi></mfenced></mrow></mfenced></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac><mo>=</mo><mo>-</mo><mn>2</mn><mi>l</mi><mi>sin</mi><mfenced><mi>&#952;</mi></mfenced><mfrac><mrow><mo>d</mo><mi>&#952;</mi></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac></math>&nbsp;and&nbsp;</p><p>Vertical velocity of <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>B</mi></math>,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>v</mi><mi>B</mi></msub><mo>=</mo><mfrac><mrow><mo>d</mo><mi>y</mi></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac><mo>=</mo><mfrac><mrow><mo>d</mo><mfenced close=\"]\" open=\"[\"><mrow><mi>l</mi><mi>sin</mi><mfenced><mi>&#952;</mi></mfenced></mrow></mfenced></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac><mo>=</mo><mi>l</mi><mi>cos</mi><mfenced><mi>&#952;</mi></mfenced><mfrac><mrow><mo>d</mo><mi>&#952;</mi></mrow><mrow><mo>d</mo><mi>t</mi></mrow></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><msub><mi>v</mi><mi>A</mi></msub><msub><mi>v</mi><mi>B</mi></msub></mfrac><mo>=</mo><mo>-</mo><mn>2</mn><mi>tan</mi><mfenced><mi>&#952;</mi></mfenced><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><msub><mi>v</mi><mi>B</mi></msub><mo>=</mo><mo>-</mo><mfrac><mrow><msub><mi>v</mi><mi>A</mi></msub><mi>cot</mi><mfenced><mi>&#952;</mi></mfenced></mrow><mn>2</mn></mfrac></math>&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"></math><br />&nbsp;<br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mtable columnalign=\"left\"><mtr><mtd><mi>&#952;</mi><mo>&#8594;</mo></mtd></mtr></mtable></math>increase</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>cot</mi><mi>&#952;</mi><mo>&#8594;</mo></math>decrease</p><p>Hence,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfenced close=\"|\" open=\"|\"><msub><mi>v</mi><mi>B</mi></msub></mfenced><mo>&#8594;</mo></math>decrease.</p>","type":"mcq","source":"JEE Main 2017 (09 Apr Online)","image":null},{"id":41309,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p><img src=\"https://.app/pyq/jee_main/74ce1095-9baa-4ab6-9ba8-53ccf3652cb5-image.png\" style=\"width: 242px; height: 160px;\" /></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>F</mi><mi>cos</mi><mi>&#952;</mi><mo>=</mo><mi>&#956;</mi><mi>N</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>F</mi><mi>sin</mi><mi>&#952;</mi><mo>+</mo><mi>N</mi><mo>=</mo><mi>m</mi><mi>g</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>F</mi><mo>=</mo><mfrac><mrow><mi>&#956;</mi><mi>mg</mi></mrow><mrow><mi>cos</mi><mi>&#952;</mi><mo>+</mo><mi>&#956;</mi><mi>sin</mi><mi>&#952;</mi></mrow></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>F</mi><mi>min</mi></msub><mo>=</mo><mfrac><mrow><mi>&#956;</mi><mi>m</mi><mi>g</mi></mrow><msqrt><mn>1</mn><mo>+</mo><msup><mi>&#956;</mi><mn>2</mn></msup></msqrt></mfrac><mo>=</mo><mfrac><mrow><mfrac><mn>1</mn><msqrt><mn>3</mn></msqrt></mfrac><mo>&#215;</mo><mn>10</mn></mrow><mfrac><mn>2</mn><msqrt><mn>3</mn></msqrt></mfrac></mfrac><mo>=</mo><mn>5</mn></math></p>","type":"mcq","source":"JEE Main 2021 (17 Mar Shift 2)","image":null},{"id":41343,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$\\sqrt{1-\\frac{1}{n^2}}$","$1-\\frac{1}{n^2}$","$\\frac{1}{2-n^2}$","$\\sqrt{\\frac{1}{1-n^2}}$"],"answer":1,"solution":"The coefficients of kinetic friction between the object and the incline\n$\\mu=\\tan \\theta\\left(1-\\frac{1}{\\mathrm{n}^2}\\right)$\n$\\Rightarrow \\mu=1-\\frac{1}{\\mathrm{n}^2} \\quad\\left(\\because \\theta=45^{\\circ}\\right)$","type":"mcq","source":"JEE Main 2018 (15 Apr Shift 1 Online)","image":null},{"id":41353,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>150</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>100</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>80</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>120</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>"],"answer":3,"solution":"<img alt=\"\" src=\"https://.app/pyq/jee_main/P_39_Ans_Correction..Amit.jpg\" style=\"width: 187px; height: 202px;\" /><br /><br />For complete state equilibrium of the system. The state friction on the block <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>B</mi></math> by&nbsp;the wall will balance the total weight <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>120</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math> of the system.","type":"mcq","source":"JEE Main 2015 (04 Apr)","image":null},{"id":41228,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<img src=\"https://.app/pyq/jee_main/fi6uJv9ppA6MS4HQ5TkP7VwHpSjDd8Sj8Vm98rdQXII.original.fullsize.png\"><br>","<img src=\"https://.app/pyq/jee_main/w65bluyESrWMpvBPHeHMIJOWQlU8myEYWReTFPCG42A.original.fullsize.png\"><br>","<img src=\"https://.app/pyq/jee_main/3bGIbn5cncOqAmpr3jyaD_-GcBnud-e0i5lzBDWG23E.original.fullsize.png\"><br>","<img src=\"https://.app/pyq/jee_main/zkDbvr_bt6jrEbLlNVQv4pVwingPKQaHNh8UGqROLmk.original.fullsize.png\"><br>"],"answer":3,"solution":"<img src=\"https://.app/pyq/jee_main/wGdPh5NVDSMDXuu9HcUQMKw7ecEqgoEGPjGPVcKHBHA.original.fullsize.png\"><br />$\\mathrm{F}=\\mathrm{ma} \\Rightarrow \\mathrm{a}=\\frac{\\mathrm{F}}{\\mathrm{m}}=\\frac{\\mathrm{kt}}{\\mathrm{m}}$\na vs $t$ will be straight line passing through origin.","type":"mcq","source":"JEE Main 2024 (04 Apr Shift 1)","image":null},{"id":41270,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>.</mo><mn>66</mn><mo>&#160;</mo><mi mathvariant=\"normal\">s</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>83</mn><mo>&#160;</mo><mi mathvariant=\"normal\">s</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn><mo>.</mo><mn>68</mn><mo>&#160;</mo><mi mathvariant=\"normal\">s</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>70</mn><mo>&#160;</mo><mi mathvariant=\"normal\">s</mi></math>"],"answer":2,"solution":"<blockquote><p><img src=\"https://.app/pyq/jee_main/7b539f87-c77f-4267-b002-fd82b6a7989f-image.png\" style=\"width: 200px; height: 142px;\" /></p><p>As per the information given in the question the lift is moving upward with uniform velocity. Therefore, the frame of reference attached to the lift is an inertial frame of reference. The acceleration of the block down the incline will be,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>a</mi><mo>=</mo><mi>g</mi><mi>sin</mi><mi>&#952;</mi></math></p></blockquote><blockquote><p>Using equation of motion for constant acceleration,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>s</mi><mo>=</mo><mi>u</mi><mi>t</mi><mo>+</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>a</mi><msup><mi>t</mi><mn>2</mn></msup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>l</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>g</mi><mi>sin</mi><mn>30</mn><mo>&#176;</mo><msup><mfenced><mn>2</mn></mfenced><mn>2</mn></msup><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>1</mn></mfenced></math></p><p>When the inclination is changed to&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>45</mn><mo>&#176;</mo></math>,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>l</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>g</mi><mi>sin</mi><mn>45</mn><mo>&#176;</mo><msup><mi>t</mi><mn>2</mn></msup><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mfenced><mn>2</mn></mfenced></math></p><p>Equating the above equations,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>g</mi><mi>sin</mi><mn>30</mn><mo>&#176;</mo><msup><mfenced><mn>2</mn></mfenced><mn>2</mn></msup><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>g</mi><mi>sin</mi><mn>45</mn><mo>&#176;</mo><msup><mfenced><mi>t</mi></mfenced><mn>2</mn></msup><mo>&#160;</mo></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfenced><mfrac><mn>1</mn><mn>2</mn></mfrac></mfenced><mfenced><mn>4</mn></mfenced><mo>=</mo><mfrac><mn>1</mn><msqrt><mn>2</mn></msqrt></mfrac><msup><mi>t</mi><mn>2</mn></msup><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mi>t</mi><mo>=</mo><msqrt><mn>2</mn><msqrt><mn>2</mn></msqrt></msqrt><mo>=</mo><mn>1</mn><mo>.</mo><mn>68</mn><mo>&#160;</mo><mi mathvariant=\"normal\">s</mi></math></p></blockquote>","type":"mcq","source":"JEE Main 2022 (27 Jul Shift 2)","image":null},{"id":41344,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math><msqrt><mn>1</mn><mo>-</mo><mfrac><mrow><mn>1</mn></mrow><mrow><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow></mfrac></msqrt></math>","<math><mn>1</mn><mo>-</mo><mfrac><mrow><mn>1</mn></mrow><mrow><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow></mfrac></math>","<math><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn><mo>-</mo><msup><mrow><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow></mfrac></math>","<math><msqrt><mfrac><mrow><mn>1</mn></mrow><mrow><msup><mrow><mn>1</mn><mo>-</mo><mi>n</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow></mfrac></msqrt></math>"],"answer":1,"solution":"<blockquote><p>Time taken to slide along a smooth surface is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>t</mi><mn>1</mn></msub></math>.<br /><math><mi>S</mi><mo>=</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mi>g</mi><mrow><mrow><mi mathvariant=\"normal\">sin</mi></mrow><mo>&#8289;</mo><mrow><msup><mrow><mn>45</mn></mrow><mrow><mi>o</mi></mrow></msup><msubsup><mrow><mi>t</mi></mrow><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></msubsup></mrow></mrow></math><br /><math><msub><mrow><mi>t</mi></mrow><mrow><mn>1</mn></mrow></msub><mo>=</mo><msqrt><mfrac><mrow><mn>2</mn><msqrt><mn>2</mn><mi>s</mi></msqrt></mrow><mrow><mi>g</mi></mrow></mfrac></msqrt></math><br />Time taken to slide along a rough surface&nbsp;is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>t</mi><mn>2</mn></msub></math>.<br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>S</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mfenced separators=\"|\"><mrow><mi>g</mi><mi>sin</mi><mo>&#8289;</mo><msup><mn>45</mn><mi>o</mi></msup><mo>-</mo><mi>&#956;</mi><mi>g</mi><mi>sin</mi><mo>&#8289;</mo><msup><mn>45</mn><mi>o</mi></msup></mrow></mfenced><mi>&#160;</mi><msubsup><mi>t</mi><mn>2</mn><mn>2</mn></msubsup></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>t</mi><mn>2</mn></msub><mo>=</mo><msqrt><mfrac><mrow><mn>2</mn><msqrt><mn>2</mn><mi>s</mi></msqrt></mrow><mrow><mi>g</mi><mfenced separators=\"|\"><mrow><mn>1</mn><mo>-</mo><mi>&#956;</mi></mrow></mfenced></mrow></mfrac></msqrt></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>t</mi><mn>2</mn></msub><mo>=</mo><mi>n</mi><msub><mi>t</mi><mn>1</mn></msub></math><br /><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mn>2</mn><msqrt><mn>2</mn><mi>s</mi></msqrt></mrow><mrow><mi>g</mi><mfenced separators=\"|\"><mrow><mn>1</mn><mo>-</mo><mi>&#956;</mi></mrow></mfenced></mrow></mfrac><mo>=</mo><msup><mi>n</mi><mn>2</mn></msup><mo>&#215;</mo><mfrac><mrow><mn>2</mn><msqrt><mn>2</mn><mi>s</mi></msqrt></mrow><mi>g</mi></mfrac><mo>&#8658;</mo><mn>1</mn><mo>-</mo><mi>&#956;</mi><mo>=</mo><mfrac><mn>1</mn><msup><mi>n</mi><mn>2</mn></msup></mfrac><mo>&#8658;</mo><mi>&#956;</mi><mo>=</mo><mn>1</mn><mo>-</mo><mfrac><mn>1</mn><msup><mi>n</mi><mn>2</mn></msup></mfrac></math></p></blockquote>","type":"mcq","source":"JEE Main 2018 (15 Apr)","image":null},{"id":41253,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>800</mn><msqrt><mn>2</mn></msqrt><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>600</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>800</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>200</mn><msqrt><mn>3</mn></msqrt><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math>"],"answer":2,"solution":"<p><img src=\"https://.app/pyq/jee_main/14d6b66b-7812-40d1-a67d-949d3909809c-b2e05771-86ea-4e22-9eac-a4eeeb69b44e-9888664_2.png\" style=\"width: 300px; height: 218px;\" /></p><p>Component of the force perpendicular to the ground,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>F</mi><mi>sin</mi><mn>30</mn><mo>&#176;</mo></math>.</p><p>Now for equilibrium along vertical direction, we get</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>N</mi><mo>=</mo><mi>m</mi><mi>g</mi><mo>+</mo><mi>F</mi><mi>sin</mi><mn>30</mn><mo>&#176;</mo><mspace linebreak=\"newline\"></mspace><mo>=</mo><mn>70</mn><mo>&#215;</mo><mn>10</mn><mo>+</mo><mn>200</mn><mo>&#215;</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mspace linebreak=\"newline\"></mspace><mo>=</mo><mn>800</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math></p>","type":"mcq","source":"JEE Main 2023 (31 Jan Shift 1)","image":null},{"id":41213,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$5,5 \\sqrt{3}$","$5 \\sqrt{3}, 5$","$5 \\sqrt{3}, 5 \\sqrt{3}$","5,5"],"answer":1,"solution":"<img src=\"https://.app/pyq/jee_main/RCJ6z_9I8Diad8u8ijC8JvOi4q0wETqdML-_-ggMdFg.original.fullsize.png\"/><br/>$\\begin{aligned} & \\mathrm{T}_1=\\mathrm{mg} \\cos 30^{\\circ} \\\\ & \\mathrm{T}_2=\\mathrm{mg} \\sin 30^{\\circ}\\end{aligned}$","type":"mcq","source":"JEE Main 2025 (2 Apr Shift 2)","image":null},{"id":41269,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>M</mi><mi>g</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>M</mi><mi>g</mi><mi>cos</mi><mi>&#952;</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mi>M</mi><mi>g</mi><mi>sin</mi><mi>&#952;</mi><mo>+</mo><mi>M</mi><mi>g</mi><mi>cos</mi><mi>&#952;</mi></msqrt></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>M</mi><mi>g</mi><mi>sin</mi><mi>&#952;</mi><msqrt><mn>1</mn><mo>+</mo><mi>&#956;</mi></msqrt></math>"],"answer":0,"solution":"<blockquote><p><img src=\"https://.app/pyq/jee_main/883977f7-5f8e-45aa-86e9-cce9dc15ea3b-image.png\" style=\"width: 200px; height: 183px;\" /></p><p>As the block moves with constant velocity, so force on the block should be balanced. The forces acting on the block are its weight, normal contact force and&nbsp;friction. The contact force is vector sum of normal contact and friction. As the forces are balanced, the contact force should be equal and opposite to its weight.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8756;</mo></math>Contact force&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mi>M</mi><mi>g</mi></math></p></blockquote>","type":"mcq","source":"JEE Main 2022 (27 Jul Shift 2)","image":null},{"id":41245,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>8</mn><mo>&#160;</mo><mi>cm</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>4</mn><mo>&#160;</mo><mo>&#160;</mo><mi>cm</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>1</mn><mo>&#160;</mo><mi>cm</mi></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>&#160;</mo><mi>cm</mi></math>"],"answer":1,"solution":"<p>The coin will slip when&nbsp;</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi><mi>m</mi><mi>g</mi><mo>=</mo><mi>m</mi><msup><mi>&#969;</mi><mn>2</mn></msup><mi>r</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>&#956;</mi><mi>g</mi><mo>=</mo><msup><mi>&#969;</mi><mn>2</mn></msup><mo>&#215;</mo><mn>1</mn><mo>&#160;</mo><mi>cm</mi><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mo>(</mo><mi>i</mi><mo>)</mo></math></p><p>Now,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#969;</mi><mo>'</mo><mo>=</mo><mfrac><mi>&#969;</mi><mn>2</mn></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi><mi>g</mi><mo>=</mo><msup><mfenced><mfrac><mi>&#969;</mi><mn>2</mn></mfrac></mfenced><mn>2</mn></msup><mi>R</mi><mo>&#160;</mo><mo>&#160;</mo><mo>&#160;</mo><mo>.</mo><mo>.</mo><mo>.</mo><mo>(</mo><mi>i</mi><mi>i</mi><mo>)</mo></math></p><p>Hence we can write from (i) and (ii)</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msup><mi>&#969;</mi><mn>2</mn></msup><mo>&#215;</mo><mn>1</mn><mo>&#160;</mo><mi>cm</mi><mo>=</mo><mfrac><msup><mi>&#969;</mi><mn>2</mn></msup><mn>4</mn></mfrac><mi>R</mi><mspace linebreak=\"newline\"/><mo>&#8658;</mo><mi>R</mi><mo>=</mo><mn>4</mn><mo>&#160;</mo><mi>cm</mi></math></p>","type":"mcq","source":"JEE Main 2023 (11 Apr Shift 1)","image":null},{"id":41390,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$0.02$","$0.03$","$0.04$","None of  these"],"answer":3,"solution":"$a=\\mu g=\\frac{6}{10}$             [ using $\\mathrm{v}=\\mathrm{u}+\\mathrm{at}$ ]\n$\\Rightarrow \\mu=\\frac{6}{10 \\times g}=\\frac{6}{10 \\times 10}=0.06$","type":"mcq","source":"JEE Main 2003","image":null},{"id":41251,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>60</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>75</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>50</mn></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn><mo>.</mo><mn>25</mn></math>"],"answer":2,"solution":"<p>Forces acting on block is shown below</p><p><img alt=\"\" src=\"https://.app/pyq/jee_main/2644f8e6-9a1b-4290-916b-5167963f6e46-Untitled.png\" style=\"width: 300px; height: 236px;\" /></p><p>From the second equation of motion,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>s</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>a</mi><msup><mi>t</mi><mn>2</mn></msup><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mn>50</mn><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mi>a</mi><mo>&#215;</mo><msup><mn>10</mn><mn>2</mn></msup><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mi>a</mi><mo>=</mo><mn>1</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>2</mn></mrow></msup></math></p><p>Applying Newton&#39;s second law in vertical direction,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>R</mi><mo>-</mo><mi>m</mi><mi>g</mi><mo>=</mo><mn>0</mn><mspace linebreak=\"newline\"></mspace><mo>&#8658;</mo><mi>R</mi><mo>=</mo><mi>m</mi><mi>g</mi></math></p><p>(where&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>R</mi></math>&nbsp;is the magnitude of normal reaction on the block due to the surface)</p><p>If <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi></math>&nbsp;is the coefficient of kinetic friction between the block and the surface, applying Newton&#39;s second law in horizontal direction,</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>30</mn><mo>-</mo><mi>&#956;</mi><mi>R</mi><mo>=</mo><mi>m</mi><mi>a</mi><mspace linebreak=\"newline\"/><mo>&#8658;</mo><mn>30</mn><mo>-</mo><mi>&#956;</mi><mi>m</mi><mi>g</mi><mo>=</mo><mi>m</mi><mi>a</mi><mspace linebreak=\"newline\"/><mo>&#8658;</mo><mn>30</mn><mo>-</mo><mn>50</mn><mi>&#956;</mi><mo>=</mo><mn>5</mn><mspace linebreak=\"newline\"/><mo>&#8658;</mo><mi>&#956;</mi><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><mo>=</mo><mn>0</mn><mo>.</mo><mn>5</mn></math></p>","type":"mcq","source":"JEE Main 2023 (01 Feb Shift 1)","image":null},{"id":41340,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$4 \\mathrm{~N}$","$14 \\mathrm{~N}$","$6 \\mathrm{~N}$","$20 \\mathrm{~N}$"],"answer":3,"solution":"Equation of motion when the mass slides down\n$$\n\\begin{aligned}\n&M g \\sin \\theta-f=M a \\\\\n&\\Rightarrow 10-f=6 \\\\\n&\\quad\\left(M=2 \\mathrm{~kg}, a=3 \\mathrm{~m} / \\mathrm{s}^2, \\theta=30^{\\circ} \\text { given }\\right) \\\\\n&\\therefore f=4 \\mathrm{~N}\n\\end{aligned}\n$$\n { Equation of motion when the block is }\npushed up\nLet the external force required to take the block up the plane with same acceleration be $F$\n$$\n\\begin{aligned}\n&F-M g \\sin \\theta-f=M a \\\\\n&\\Rightarrow F-10-4=6 \\\\\n&F=20 \\mathrm{~N}\n\\end{aligned}\n$$\n<img src=\"https://.app/pyq/jee_main/L9IYGTS3F-mT2NUjpIzx_ScLFuOITev7LXPkq4ltPh8.original.fullsize.png\"><br>","type":"mcq","source":"JEE Main 2018 (15 Apr Shift 2 Online)","image":null},{"id":41349,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math><mrow><mrow><mi mathvariant=\"normal\">tan</mi></mrow><mo>⁡</mo><mrow><mn>2</mn><mi mathvariant=\"normal\">θ</mi></mrow></mrow></math>","<math><mrow><mrow><mi mathvariant=\"normal\">tan</mi></mrow><mo>⁡</mo><mrow><mi mathvariant=\"normal\">θ</mi></mrow></mrow></math>","<math><mn>3</mn><mrow><mrow><mi mathvariant=\"normal\">tan</mi></mrow><mo>⁡</mo><mrow><mi mathvariant=\"normal\">θ</mi></mrow></mrow></math>","<math><mn>2</mn><mrow><mrow><mi mathvariant=\"normal\">tan</mi></mrow><mo>⁡</mo><mrow><mi mathvariant=\"normal\">θ</mi></mrow></mrow></math>"],"answer":1,"solution":"<img src=\"https://.app/pyq/jee_main/fcdfdc68-2a17-4370-a443-6646673b71a6-image.png\" style=\"width: 350px; height: 201px;\" /><img src=\"https://.app/pyq/jee_main/f11d799d-4966-49a8-969a-f6d0fa6e430e-image.png\" style=\"width: 250px; height: 156px;\" /><br /><br /><math><mn>3</mn><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">g</mi><mrow><mrow><mi mathvariant=\"normal\">sin</mi></mrow><mo>&#8289;</mo><mrow><mi mathvariant=\"normal\">&#952;</mi></mrow></mrow><mo>=</mo><mi mathvariant=\"normal\">&#956;</mi><mn>3</mn><mi mathvariant=\"normal\">m</mi><mi mathvariant=\"normal\">g</mi><mrow><mrow><mi mathvariant=\"normal\">cos</mi></mrow><mo>&#8289;</mo><mrow><mi mathvariant=\"normal\">&#952;</mi></mrow></mrow></math><br /><br /><math><mi mathvariant=\"normal\">&#956;</mi><mo>=</mo><mrow><mrow><mi mathvariant=\"normal\">tan</mi></mrow><mo>&#8289;</mo><mrow><mi mathvariant=\"normal\">&#952;</mi></mrow></mrow></math>","type":"mcq","source":"JEE Main 2016 (09 Apr Online)","image":null},{"id":41379,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$\\mu_{\\mathrm{k}}=1-\\frac{1}{\\mathrm{n}^2}$","$\\mu_{\\mathrm{k}}=\\sqrt{1-\\frac{1}{\\mathrm{n}^2}}$","$\\mu_s=1-\\frac{1}{n^2}$","$\\mu_s=\\sqrt{1-\\frac{1}{n^2}}$"],"answer":0,"solution":"$\\mathrm{d}=\\frac{1}{2} \\frac{\\mathrm{g}}{\\sqrt{2}} \\mathrm{t}_1^2$\n$\\mathrm{~d}=\\frac{1}{2} \\frac{\\mathrm{g}}{\\sqrt{2}}\\left(1-\\mu_{\\mathrm{k}}\\right) \\mathrm{t}_2^2$\n$\\frac{\\mathrm{t}_2^2}{\\mathrm{t}_1^2}=\\mathrm{n}^2=\\frac{1}{1-\\mu_{\\mathrm{k}}}$","type":"mcq","source":"JEE Main 2005","image":null},{"id":41388,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["less than $\\overrightarrow{\\mathrm{v}}$","greater than $\\overrightarrow{\\mathrm{v}}$","$|\\mathrm{v}|$ in the direction of the largest force $\\mathrm{BC}$","$\\overrightarrow{\\mathrm{v}}$, remaining unchanged"],"answer":3,"solution":"According to triangle law of forces, the resultant force is zero.\nIn presence of zero external force, there is no change in velocity","type":"mcq","source":"JEE Main 2003","image":null},{"id":41304,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>t</mi><mi>a</mi></msub><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><msub><mi>t</mi><mi>d</mi></msub></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mfrac><mrow><mn>2</mn><mo>&#160;</mo><mi>s</mi></mrow><msub><mi>a</mi><mi>a</mi></msub></mfrac></msqrt><mo>=</mo><mfrac><mn>1</mn><mn>2</mn></mfrac><msqrt><mfrac><mrow><mn>2</mn><mo>&#160;</mo><mi>s</mi></mrow><msub><mi>a</mi><mi>d</mi></msub></mfrac></msqrt><mo>&#160;</mo><mo>&#8230;</mo><mfenced><mi mathvariant=\"normal\">i</mi></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>a</mi><mi mathvariant=\"italic\">a</mi></msub><mo>=</mo><mi>g</mi><mi>sin</mi><mi>&#952;</mi><mo>+</mo><mi>&#956;</mi><mi>g</mi><mi>cos</mi><mi>&#952;</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mi>g</mi><mn>2</mn></mfrac><mo>+</mo><mfrac><msqrt><mn>3</mn></msqrt><mn>2</mn></mfrac><mi>&#956;</mi><mi>g</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>a</mi><mi mathvariant=\"italic\">d</mi></msub><mo>=</mo><mi>g</mi><mi>sin</mi><mi>&#952;</mi><mo>-</mo><mi>&#956;</mi><mi>g</mi><mi>cos</mi><mi>&#952;</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>=</mo><mfrac><mi>g</mi><mn>2</mn></mfrac><mo>-</mo><mfrac><msqrt><mn>3</mn></msqrt><mn>2</mn></mfrac><mi>&#956;</mi><mi>g</mi></math></p><p>Using the above values of <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>a</mi><mi>a</mi></msub></math> and <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>a</mi><mi>d</mi></msub></math> and putting in<br />equation&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfenced><mi mathvariant=\"normal\">i</mi></mfenced></math>, we will get,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi><mo>=</mo><mfrac><msqrt><mn>3</mn></msqrt><mn>5</mn></mfrac></math></p>","type":"mcq","source":"JEE Main 2021 (20 Jul Shift 2)","image":null},{"id":41366,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$\\theta=\\tan ^{-1}(\\mu), F=\\frac{\\mu W}{\\sqrt{1+\\mu^2}}$","$\\theta=\\tan ^{-1}\\left(\\frac{1}{\\mu}\\right), F=\\frac{\\mu W}{\\sqrt{1+\\mu^2}}$","$\\theta=0, F=\\mu W$","$\\theta=\\tan ^{-1}\\left(\\frac{\\mu}{1+\\mu}\\right), F=\\frac{\\mu W}{1+\\mu}$"],"answer":0,"solution":"Let the force $F$ is applied at an angle $\\theta$ with the horizontal.\n<img src=\"https://.app/pyq/jee_main/pK9-C8aYZ0g71NL8VJCDOmLPkfkSipV_Td2hJ-BuVAA.original.fullsize.png\"><br>\nFor horizontal equilibrium, $F \\cos \\theta=\\mu R$\nFor vertical equilibrium, $R+F \\sin \\theta=\\mathrm{mg}$ or, $R=m g-F \\sin \\theta$ Substituting this value of $R$ in eq. (i), we get\n$$\n\\begin{aligned}\n& F \\cos \\theta=\\mu(\\mathrm{mg}-F \\sin \\theta) \\\\\n& =\\mu \\mathrm{mg}-\\mu F \\sin \\theta \\\\\n& \\text { or, } F(\\cos \\theta+\\mu \\sin \\theta)=\\mu \\mathrm{mg} \\\\\n& \\text { or, } \\mathrm{F}=\\frac{\\mu \\mathrm{mg}}{\\cos \\theta+\\mu \\sin \\theta}\n\\end{aligned}\n$$\nFor $F$ to be minimum, the denominator $(\\cos \\theta+\\mu \\sin \\theta)$ should be maximum.\n$$\n\\therefore \\frac{d}{d \\theta}(\\cos \\theta+\\mu \\sin \\theta)=0\n$$\nor, $-\\sin \\theta+\\mu \\cos \\theta=0$\nor, $\\tan \\theta=\\mu$\nor, $\\theta=\\tan ^{-1}(\\mu)$\nThen, $\\sin \\theta=\\frac{\\mu}{\\sqrt{1+\\mu^2}}$ and\n$$\n\\cos \\theta=\\frac{1}{\\sqrt{1+\\mu^2}}\n$$\nHence, $F_{\\text {min }}$\n$$\n=\\frac{\\mu w}{\\frac{1}{\\sqrt{1+\\mu^2}}+\\frac{\\mu^2}{\\sqrt{1+\\mu^2}}}=\\frac{\\mu w}{\\sqrt{1+\\mu^2}}\n$$","type":"mcq","source":"JEE Main 2012 (19 May Online)","image":null},{"id":41372,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["Statement $1$ is false, Statement $2$ is true","Statement $1$ is true, Statement $2$ is false","Statement $1$ is true, Statement $2$ is the correct explanation for statement $1$","Statement $1$ is true, Statement $2$ is true, Statement $2$ is not the correct explanation for statement $1$."],"answer":0,"solution":"$\\mathrm{F}=\\mathrm{K}_1 \\mathrm{S}_1=\\mathrm{K}_2 \\mathrm{S}_2$\n$\\mathrm{W}_1=\\mathrm{FS}_1, \\mathrm{~W}_2=\\mathrm{FS}_2$\n$\\mathrm{K}_1 \\mathrm{S}_1{ }^2>\\mathrm{K}_2 \\mathrm{S}_2^2$\n$\\mathrm{S}_1>\\mathrm{S}_2$\n$\\mathrm{K}_1 < \\mathrm{K}_2$\n$\\mathrm{W} \\propto \\mathrm{K}$\n$\\mathrm{W}_1 < \\mathrm{W}_2$","type":"mcq","source":"JEE Main 2012 (Offline)","image":null},{"id":41207,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$\\frac{2 u^{2}}{\\cos \\theta}$","$\\frac{u^{2}}{2 g \\sin \\theta}$","$\\frac{u^{2}}{2 g \\cos \\theta}$","$\\frac{u^{2}}{\\sqrt{2} g \\cos \\theta}$"],"answer":1,"solution":"$a = -g\\sin\\theta$<br>$V^2 = U^2 + 2as$<br>$0 = u^2 - 2g\\sin\\theta \\cdot s$<br>$s = \\dfrac{u^2}{2g\\sin\\theta}$","type":"mcq","source":"JEE Main 2026 (23 January Shift 2)","image":null},{"id":41235,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mi>μ</mi><mi>g</mi></mrow><mi>r</mi></mfrac></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mfrac><mi>r</mi><mrow><mi>μ</mi><mi>g</mi></mrow></mfrac></msqrt></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mfrac><mrow><mi>μ</mi><mi>g</mi></mrow><mi>r</mi></mfrac></msqrt></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mi>μ</mi><msqrt><mi>r</mi><mi>g</mi></msqrt></mfrac></math>"],"answer":2,"solution":"<p><img src=\"https://.app/pyq/jee_main/86ffa3e5-47e5-43c3-a6b2-5f0bf762019c.png\" style=\"width: 350px; height: 202px;\"/></p><p>Normal force acting on the coin is, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>N</mi><mo>=</mo><mi>m</mi><mi>g</mi></math>.</p><p>Required friction force to provide centripetal force for the coin is, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>f</mi><mo>=</mo><mi>m</mi><msup><mi>ω</mi><mn>2</mn></msup><mi>r</mi></math> and maximum value of static friction force available is, <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>f</mi><mo>=</mo><mi>μ</mi><mi>N</mi><mo>=</mo><mi>μ</mi><mi>m</mi><mi>g</mi></math>.</p><p>For limiting condition, we can write</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>⇒</mo><mi>μ</mi><mi>m</mi><mi>g</mi><mo>=</mo><mi>m</mi><mi>r</mi><msup><mi>ω</mi><mn>2</mn></msup></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>⇒</mo><mi>ω</mi><mo>=</mo><msqrt><mfrac><mrow><mi>μ</mi><mi>g</mi></mrow><mi>r</mi></mfrac></msqrt></math></p>","type":"mcq","source":"JEE Main 2024 (31 Jan Shift 1)","image":null},{"id":41275,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mn>2</mn></msqrt><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi><mo>,</mo><mn>45</mn><mo>&#176;</mo></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msqrt><mn>2</mn></msqrt><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi><mo>,</mo><mn>135</mn><mo>&#176;</mo></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>2</mn><msqrt><mn>3</mn></msqrt></mfrac><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi><mo>,</mo><mn>30</mn><mo>&#176;</mo></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>2</mn><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi><mo>,</mo><mn>45</mn><mo>&#176;</mo></math>"],"answer":0,"solution":"<blockquote><p>Let additional force required be&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover><mi mathvariant=\"normal\">F</mi><mo>&#8594;</mo></mover></math>.</p><p>Vector sum of the four forces and additional force.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover><mi mathvariant=\"normal\">F</mi><mo>&#8594;</mo></mover><mo>+</mo><mn>5</mn><mover><mi>i</mi><mo>^</mo></mover><mo>-</mo><mn>6</mn><mover><mi>i</mi><mo>^</mo></mover><mo>+</mo><mn>7</mn><mover><mi>j</mi><mo>^</mo></mover><mo>-</mo><mn>8</mn><mover><mi>j</mi><mo>^</mo></mover><mo>=</mo><mn>0</mn></math></p><p>Force required to make net acceleration&nbsp;zero</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mover><mi mathvariant=\"normal\">F</mi><mo>&#8594;</mo></mover><mo>=</mo><mover><mi>i</mi><mo>^</mo></mover><mo>+</mo><mover><mi>j</mi><mo>^</mo></mover></math></p><p>Therefore, the required force is&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfenced close=\"|\" open=\"|\"><mover><mi mathvariant=\"normal\">F</mi><mo>&#8594;</mo></mover></mfenced><mo>=</mo><msqrt><msup><mn>1</mn><mn>2</mn></msup><mo>+</mo><msup><mn>1</mn><mn>2</mn></msup></msqrt><mo>=</mo><msqrt><mn>2</mn></msqrt><mo>&#160;</mo><mi mathvariant=\"normal\">N</mi></math></p><p>Angle with&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>x</mi></math>-axis:&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>tan</mi><mi>&#952;</mi><mo>=</mo><mfrac><mrow><mi>y</mi><mo>&#160;</mo><mi>component</mi><mo>&#160;</mo></mrow><mrow><mi>x</mi><mo>&#160;</mo><mi>component</mi><mo>&#160;</mo></mrow></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>1</mn></mfrac></math></p><p>Thus,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#952;</mi><mo>=</mo><mn>45</mn><mo>&#176;</mo></math></p></blockquote>","type":"mcq","source":"JEE Main 2022 (25 Jul Shift 2)","image":null},{"id":41370,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$m v^3$","$m v^2$","$\\frac{1}{2} m v^2$","$\\frac{1}{2} m v^3$"],"answer":1,"solution":"As power $\\mathrm{P}=F . v .=\\frac{F \\ell}{t}$\n$$\n\\begin{aligned}\n& \\text { or, } v\\left(M \\frac{v}{t}\\right)=\\frac{F . \\ell}{t} \\\\\n& \\Rightarrow \\quad M v^2=F \\ell \\ell \\\\\n& \\Rightarrow \\quad F=\\frac{M}{\\ell} v^2=m v^2 \\\\\n& {\\left[\\because \\frac{M}{\\ell}=m(\\text { given })\\right]}\n\\end{aligned}\n$$","type":"mcq","source":"JEE Main 2012 (07 May Online)","image":null},{"id":41259,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mn>2</mn><msqrt><mn>3</mn></msqrt><mo>+</mo><mn>1</mn></mrow><mn>2</mn></mfrac></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>1</mn><mrow><mn>2</mn><msqrt><mn>3</mn></msqrt></mrow></mfrac></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><msqrt><mn>3</mn></msqrt><mn>2</mn></mfrac></math>","<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mrow><mn>2</mn><msqrt><mn>3</mn></msqrt><mo>-</mo><mn>1</mn></mrow><mn>2</mn></mfrac></math>"],"answer":1,"solution":"<p><img alt=\"\" src=\"https://.app/pyq/jee_main/78f246e7-f16c-4064-b070-0327695076e5-0a278a3c-a09a-4972-8990-ff4088cf7728-9886900.png\" style=\"width: 300px; height: 206px;\" /></p><p>Applying Newton&#39;s second law along the direction perpendicular to inlined plane:</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>N</mi><mo>-</mo><mi>m</mi><mi>g</mi><mi>cos</mi><msup><mn>30</mn><mo>&#8728;</mo></msup><mo>=</mo><mn>0</mn></math>&nbsp;(As <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#952;</mi><mo>=</mo><mn>30</mn><mo>&#176;</mo></math>)</p><p>(since the acceleration of block in the direction perpendicular to the inclined plane is <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>0</mn></math>)</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8756;</mo><mi>N</mi><mo>=</mo><mi>m</mi><mi>g</mi><mi>cos</mi><msup><mn>30</mn><mo>&#8728;</mo></msup></math>&nbsp; &nbsp;.....(1)</p><p>Let <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi></math>&nbsp;be the coefficient of kinetic friction between the block and the inclined plane. Applying Newton&#39;s second law along inclined plane:</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>m</mi><mi>g</mi><mi>sin</mi><msup><mn>30</mn><mo>&#8728;</mo></msup><mo>-</mo><mi>&#956;</mi><mi>N</mi><mo>=</mo><mi>m</mi><mi>a</mi><mo>=</mo><mi>m</mi><mfrac><mi>g</mi><mn>4</mn></mfrac></math>&nbsp; &nbsp; ....(2)</p><p>(since the acceleration along the inclined plane,&nbsp;&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>a</mi><mo>=</mo><mfrac><mi>g</mi><mn>4</mn></mfrac></math>)</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8756;</mo><mi>m</mi><mi>g</mi><mi>sin</mi><msup><mn>30</mn><mo>&#8728;</mo></msup><mo>-</mo><mi>&#956;</mi><mi>m</mi><mi>g</mi><mi>cos</mi><msup><mn>30</mn><mo>&#8728;</mo></msup><mo>=</mo><mi>m</mi><mfrac><mi>g</mi><mn>4</mn></mfrac></math>&nbsp; &nbsp;(from equation 1 and 2)</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mrow><mi>m</mi><mi>g</mi></mrow><mn>2</mn></mfrac><mo>-</mo><mfrac><msqrt><mn>3</mn></msqrt><mn>2</mn></mfrac><mi>&#956;</mi><mi>m</mi><mi>g</mi><mo>=</mo><mi>m</mi><mfrac><mi>g</mi><mn>4</mn></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo></math><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi><mo>=</mo><mfrac><mn>1</mn><mrow><mn>2</mn><msqrt><mn>3</mn></msqrt></mrow></mfrac></math></p>","type":"mcq","source":"JEE Main 2023 (29 Jan Shift 1)","image":null},{"id":41295,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>Given</p><p>Translation <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi mathvariant=\"normal\">K</mi><mo>.</mo><mi mathvariant=\"normal\">E</mi><mo>.</mo></math>&nbsp;of <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><msub><mi>N</mi><mn>2</mn></msub><mo>=</mo><mi mathvariant=\"normal\">K</mi><mo>.</mo><mi mathvariant=\"normal\">E</mi></math> of electron</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>3</mn><mn>2</mn></mfrac><mi>k</mi><mi>T</mi><mo>=</mo><mi>e</mi><mi>V</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mfrac><mn>3</mn><mn>2</mn></mfrac><mo>&#215;</mo><mn>1</mn><mo>.</mo><mn>38</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>23</mn></mrow></msup><mo>&#160;</mo><mi mathvariant=\"normal\">T</mi><mo>=</mo><mn>1</mn><mo>.</mo><mn>6</mn><mo>&#215;</mo><msup><mn>10</mn><mrow><mo>-</mo><mn>19</mn></mrow></msup><mo>&#215;</mo><mn>0</mn><mo>.</mo><mn>1</mn><mo>&#160;&#160;</mo><mo>&#8658;</mo><mi>T</mi><mo>=</mo><mn>773</mn><mo>&#160;</mo><mi mathvariant=\"normal\">K</mi></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>T</mi><mo>=</mo><mn>773</mn><mo>-</mo><mn>273</mn><mo>=</mo><mn>500</mn><mo>&#176;</mo><mi mathvariant=\"normal\">C</mi></math></p>","type":"mcq","source":"JEE Main 2021 (01 Sep Shift 2)","image":null},{"id":41198,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["$1:2$","$2:5$","$5:2$","$5:4$"],"answer":3,"solution":"Mass $m = 100 \\text{ g} = 0.1 \\text{ kg}$<br><br>Force $\\vec{F} = 5\\hat{i} + 10\\hat{j} \\text{ N}$<br><br>Acceleration $\\vec{a} = \\dfrac{\\vec{F}}{m} = \\dfrac{5\\hat{i} + 10\\hat{j}}{0.1} = 50\\hat{i} + 100\\hat{j} \\text{ m/s}^2$<br><br>Since the body starts from rest, initial velocity $\\vec{u} = 0$.<br><br>Position after $t = 2 \\text{ s}$ is given by $\\vec{r} = \\vec{u}t + \\dfrac{1}{2}\\vec{a}t^2$<br><br>$\\vec{r} = \\dfrac{1}{2}(50\\hat{i} + 100\\hat{j})(2)^2 = 100\\hat{i} + 200\\hat{j} \\text{ m}$<br><br>Comparing with the given position $\\vec{r} = 2x\\hat{i} + 5y\\hat{j}$:<br><br>$2x = 100 \\Rightarrow x = 50$<br><br>$5y = 200 \\Rightarrow y = 40$<br><br>The ratio $x:y = 50:40 = 5:4$<br><br>Answer: $5:4$","type":"mcq","source":"JEE Main 2026 (04 April Shift 2)","image":null},{"id":41205,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["60","15","20","45"],"answer":0,"solution":"Spring force constant is inversely proportional to length: $k \\propto \\frac{1}{L}$ <br>So $kL = $ constant for a given spring material and structure.<br>Original spring: $k = 15$ N/m, length $= L$.<br>Smaller piece has length $\\frac{L}{4}$ (since length ratio is 1:3, smaller is $\\frac{1}{4}$ of total).<br>For smaller piece: $k_1 \\times \\frac{L}{4} = 15 \\times L$<br>$k_1 = 15 \\times 4 = 60$ N/m","type":"mcq","source":"JEE Main 2026 (24 January Shift 1)","image":null},{"id":41217,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["39 N","15 N","11 N","20 N"],"answer":2,"solution":"$\\begin{aligned} & \\mathrm{kx}_1=5 \\mathrm{~N} \\\\ & \\mathrm{kx}_2=7 \\mathrm{~N} \\\\ & \\mathrm{k}\\left(5 \\mathrm{x}_1-2 \\mathrm{x}_2\\right)=5 \\mathrm{kx}_1-2 \\mathrm{kx}_2 \\\\ & =5 \\times 5-2 \\times 7=11 \\mathrm{~N}\\end{aligned}$","type":"mcq","source":"JEE Main 2025 (23 Jan Shift 2)","image":null},{"id":41289,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["A","B","C","D"],"answer":0,"solution":"<p>The maximum speed is given as&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>v</mi><mo>=</mo><msqrt><mi>&#956;</mi><mi>g</mi><mi>r</mi></msqrt></math>, where,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>&#956;</mi></math>&nbsp;is coefficient of friction and&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>r</mi></math>&nbsp;is radius of curved road.</p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><msub><mi>v</mi><mn>1</mn></msub><msub><mi>v</mi><mn>2</mn></msub></mfrac><mo>=</mo><msqrt><mfrac><msub><mi>r</mi><mn>1</mn></msub><msub><mi>r</mi><mn>2</mn></msub></mfrac></msqrt></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mfrac><mn>30</mn><msub><mi>v</mi><mn>2</mn></msub></mfrac><mo>=</mo><msqrt><mfrac><mn>75</mn><mn>48</mn></mfrac></msqrt><mo>=</mo><msqrt><mfrac><mn>25</mn><mn>16</mn></mfrac></msqrt><mo>=</mo><mfrac><mn>5</mn><mn>4</mn></mfrac></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><msub><mi>v</mi><mn>2</mn></msub><mo>=</mo><mn>24</mn><mo>&#160;</mo><mi mathvariant=\"normal\">m</mi><mo>&#160;</mo><msup><mi mathvariant=\"normal\">s</mi><mrow><mo>-</mo><mn>1</mn></mrow></msup></math></p>","type":"mcq","source":"JEE Main 2022 (25 Jun Shift 2)","image":null},{"id":41337,"subject":"Physics","chapter":"Laws of Motion","question":"","options":["<math><mo>-</mo><mfrac><mrow><mi>m</mi><msup><mrow><mi>g</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>8</mn></mrow></mfrac></math>","<math><mfrac><mrow><mi>m</mi><mi> </mi><msup><mrow><mi>g</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>8</mn></mrow></mfrac></math>","<math><mn>0</mn></math>","<math><mfrac><mrow><mn>3</mn><mi>&nbsp;</mi><mi>m</mi><mi>&nbsp;</mi><msup><mrow><mi>g</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>8</mn></mrow></mfrac></math>"],"answer":3,"solution":"<img src=\"https://.app/pyq/jee_main/spdbzrbxamgsfyqjrebgqhrzkmoncqdxmxpcqkdedpfdvjsefq.png\" /><br /><math><mi>N</mi><mo>-</mo><mi>m</mi><mi>g</mi><mo>=</mo><mfrac><mrow><mi>m</mi><mi>g</mi></mrow><mrow><mn>2</mn></mrow></mfrac></math><br /><math><mi>N</mi><mo>=</mo><mfrac><mrow><mn>3</mn><mi>m</mi><mi>g</mi></mrow><mrow><mn>2</mn></mrow></mfrac></math><br /><math><mi>s</mi><mo>=</mo><mi>u</mi><mi>t</mi><mo>+</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mi>a</mi><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></math><br /><math><mo>=</mo><mn>0</mn><mo>+</mo><mfrac><mrow><mn>1</mn></mrow><mrow><mn>2</mn></mrow></mfrac><mfrac><mrow><mi>g</mi></mrow><mrow><mn>2</mn></mrow></mfrac><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></math><br /><math><mo>=</mo><mfrac><mrow><mi>g</mi></mrow><mrow><mn>4</mn></mrow></mfrac></math><math> <mrow> <msup> <mi>t</mi> <mn>2</mn> </msup> </mrow> </math><br /><math><msub><mrow><mi>W</mi></mrow><mrow><mi>N</mi></mrow></msub><mo>=</mo><mfrac><mrow><mn>3</mn><mi>m</mi><mi>g</mi></mrow><mrow><mn>2</mn></mrow></mfrac><mo>&#215;</mo><mfrac><mrow><mi>g</mi></mrow><mrow><mn>4</mn></mrow></mfrac><mi>&#160;</mi><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></math><br /><math><mo>=</mo><mfrac><mrow><mn>3</mn><mi>m</mi><msup><mrow><mi>g</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>8</mn></mrow></mfrac><mo>=</mo><mfrac><mrow><mn>3</mn><mi>m</mi><msup><mrow><mi>g</mi></mrow><mrow><mn>2</mn></mrow></msup><msup><mrow><mi>t</mi></mrow><mrow><mn>2</mn></mrow></msup></mrow><mrow><mn>8</mn></mrow></mfrac></math>","type":"mcq","source":"JEE Main 2019 (10 Jan Shift 1)","image":null},{"id":41258,"subject":"Physics","chapter":"Laws of Motion","question":"","options":[