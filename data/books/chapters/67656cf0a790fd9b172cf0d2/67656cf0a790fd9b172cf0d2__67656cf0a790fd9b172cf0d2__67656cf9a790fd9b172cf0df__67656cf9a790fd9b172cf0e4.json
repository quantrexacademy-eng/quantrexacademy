n></mfrac></math>.</p>", "difficulty": "Easy", "source": "JEE Main 2022 (26 Jun Shift 1)", "_marksId": "648b5a6d417cc3fb48d67a58"}, {"id": 0, "subject": "Mathematics", "chapter": "Trigonometry", "exam": "Engineering", "examName": "Top 100 Numerical Qs of JEE Main 2023-2020", "q": "The number of integral values of <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>k</mi></math>&nbsp;for which the equation <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>3</mn><mi>sin</mi><mi>x</mi><mo>+</mo><mn>4</mn><mi>cos</mi><mi>x</mi><mo>=</mo><mi>k</mi><mo>+</mo><mn>1</mn></math> has a solution,&nbsp;<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>k</mi><mo>&#8712;</mo><mi>R</mi></math> is _______.", "options": ["A", "B", "C", "D"], "answer": 0, "solution": "<math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mn>3</mn><mi>sin</mi><mi>x</mi><mo>+</mo><mn>4</mn><mi>cos</mi><mi>x</mi><mo>=</mo><mi>k</mi><mo>+</mo><mn>1</mn></math><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>k</mi><mo>+</mo><mn>1</mn><mo>&#8712;</mo><mfenced close=\"]\" open=\"[\"><mrow><mo>-</mo><msqrt><msup><mn>3</mn><mn>2</mn></msup><mo>+</mo><msup><mn>4</mn><mn>2</mn></msup></msqrt><mo>,</mo><msqrt><msup><mn>3</mn><mn>2</mn></msup><mo>+</mo><msup><mn>4</mn><mn>2</mn></msup></msqrt></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>k</mi><mo>+</mo><mn>1</mn><mo>&#8712;</mo><mfenced close=\"]\" open=\"[\"><mrow><mo>-</mo><mn>5</mn><mo>,</mo><mn>5</mn></mrow></mfenced></math></p><p><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mo>&#8658;</mo><mi>k</mi><mo>&#8712;</mo><mfenced close=\"]\" open=\"[\"><mrow><mo>-</mo><mn>6</mn><mo>,</mo><mn>4</mn></mrow></mfenced></math></p><p>No. of integral values of <math xmlns=\"http://www.w3.org/1998/Math/MathML\"><mi>k</mi><mo>=</mo><mn>11</mn></math></p>", "difficulty": "Medium", "source": "JEE Main 2021 (26 Feb Shift 1)", "_marksId": "648b5a6b417cc3fb48d674b6"}]}