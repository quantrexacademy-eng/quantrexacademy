rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validProgress() {
      return request.resource.data.keys().hasAll(['exam', 'bookmarks', 'solved', 'notes', 'attempts'])
        && request.resource.data.exam is string
        && request.resource.data.bookmarks is list
        && request.resource.data.solved is list
        && request.resource.data.notes is list
        && request.resource.data.attempts is list
        && request.resource.data.bookmarks.size() <= 5000
        && request.resource.data.solved.size() <= 50000
        && request.resource.data.notes.size() <= 1000
        && request.resource.data.attempts.size() <= 500;
    }

    // User profile
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.exam is string;
      allow update: if isOwner(userId)
        && request.resource.data.uid == userId;

      // User progress (bookmarks, solved, notes, attempts)
      match /data/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validProgress();
        allow delete: if isOwner(userId);
      }
    }

    // App metadata (public read)
    match /app/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Question bank seed (read only for logged-in users)
    match /content/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Payment records (user reads own, server writes via admin SDK)
    match /payments/{paymentId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Subscription status
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}